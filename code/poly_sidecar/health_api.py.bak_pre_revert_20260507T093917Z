@app.post("/debate/upload")
async def debate_upload(file: UploadFile = File(...)):
    """Recibe MP3 / WAV y lo guarda en debatebots_uploads."""
    if not file.filename:
        raise HTTPException(400, "no filename")
    # Sanitize: solo basename, sin paths
    safe_name = os.path.basename(file.filename).replace("..", "_")
    if not safe_name.lower().endswith((".mp3", ".wav", ".m4a", ".ogg", ".flac")):
        raise HTTPException(400, f"extensión no permitida: {safe_name}")
    out_path = DEBATE_UPLOAD_DIR / safe_name
    contents = await file.read()
    if len(contents) > 50 * 1024 * 1024:
        raise HTTPException(413, "archivo > 50 MB")
    out_path.write_bytes(contents)
    return {"ok": True, "filename": safe_name, "size": len(contents),
            "path": str(out_path)}


@app.get("/debate/file/{name}")
def debate_file(name: str):
    """Sirve el archivo subido para preview en la UI."""
    safe = os.path.basename(name)
    p = DEBATE_UPLOAD_DIR / safe
    if not p.exists():
        raise HTTPException(404, "not found")
    return FileResponse(p, media_type="audio/mpeg" if safe.lower().endswith(".mp3") else "audio/wav")
