    age = store.heartbeat_age_seconds()
    stale = store.is_stale(max_age_seconds=600)
    if not s:
        return {
            "status": "uninitialized",
            "tau_final": 0.0,
            "tau_macro": 0.0,
            "tau_crypto": 0.0,
            "heartbeat_age_seconds": None,
            "is_stale": True,
            "endpoints_errors": {},
            "per_contract": [],
            "served_at": time.time(),
