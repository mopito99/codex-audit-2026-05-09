# ══════════════════════════════════════════════════════════════════════
# EcoArb · Newark (mbottoken-arbsol-ewr2) — .env completo
# Copiar a /home/administrator/solana_executor_rs/.env y rellenar valores
# NUNCA commitear este archivo con valores reales
# ══════════════════════════════════════════════════════════════════════

# ── Modo de operación ──────────────────────────────────────────────────
# true  = paper mode (simula, logea en JSONL, sin dinero real)
# false = LIVE mode  (dinero real — solo cambiar cuando paper valide métricas)
PAPER_MODE=true

# ── Hot Wallet ─────────────────────────────────────────────────────────
# GaL85ykdeJ9g5JeXE2Yvar92yMktVCzvi5vGJB77wbTh
# Clave privada en base58 (Keypair completo, 64 bytes)
WALLET_PRIVATE_KEY=

# ── Chainstack (RPC + WSS + gRPC Yellowstone) ──────────────────────────
# Nodo: ND-473-445-892 | Proyecto: PR-402-833 | Red: NW-735-225-2
# Encontrar endpoints en console.chainstack.com → tu nodo → "Access and credentials"
CHAINSTACK_RPC_URL=https://solana-mainnet.core.chainstack.com/XXXX
CHAINSTACK_WSS_URL=wss://solana-mainnet.core.chainstack.com/XXXX
CHAINSTACK_GRPC_URL=https://solana-mainnet.core.chainstack.com:2053
CHAINSTACK_GRPC_TOKEN=

# ── Helius (fallback RPC si Chainstack falla) ───────────────────────────
HELIUS_API_KEY=13f1f82a-XXXX-XXXX-XXXX-XXXXXXXXXXXX

# ── Precio SOL (para cálculos epsilon — actualizar manualmente si varía >10%) ──
SOL_PRICE_USD=175.0

# ── Jito tips ──────────────────────────────────────────────────────────
# Base: 100_000 lamports (~$0.0175 @ $175 SOL)
# El bot ajusta automáticamente por hora (PEAK × 1.8, ASIA × 1.3)
JITO_TIP_LAMPORTS=100000
JITO_TIP_MULT_PEAK=1.8
JITO_TIP_MULT_ASIA=1.3

# ── Ventanas horarias LIVE (UTC decimal) ───────────────────────────────
# Ventana 1 — americana: 17:30-19:30 UTC (alta competencia, mayor volumen)
LIVE_HOURS_START=17.5
LIVE_HOURS_END=19.5
# Ventana 2 — asiática: 03:00-05:00 UTC (G10: 3× más oportunidades)
LIVE_HOURS_START2=3.0
LIVE_HOURS_END2=5.0

# ── Logging ────────────────────────────────────────────────────────────
# Los JSONL se generan aquí y se rsyncan a Dallas por el evaluator timer
LOG_DIR=/home/administrator/solana_executor_rs/data

# ── Métricas Prometheus (G49) ──────────────────────────────────────────
# Expone /metrics en este puerto — Grafana/Prometheus en Dallas hace scrape
METRICS_PORT=9090
