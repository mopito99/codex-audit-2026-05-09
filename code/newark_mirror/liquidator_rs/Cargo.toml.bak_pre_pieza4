[package]
name = "liquidator_rs"
version = "0.1.0"
edition = "2024"

[dependencies]
solana-sdk = "2.0"
solana-client = "2.0"

tokio = { version = "1.36", features = ["full"] }
tokio-stream = "0.1"
futures = "0.3"

# gRPC Yellowstone (Chainstack)
yellowstone-grpc-client = "12.2"
yellowstone-grpc-proto = "12.3"
tonic = { version = "0.14", features = ["tls-ring", "tls-native-roots"] }

# HTTP (Jito later)
reqwest = { version = "0.11", features = ["json", "rustls-tls"] }
serde = { version = "1.0", features = ["derive"] }
serde_json = "1.0"

rand = "0.8"
bincode = "1.3.3"

# Encoding
bs58 = "0.5"
base64 = "0.21"
borsh = { version = "1.5", features = ["derive"] }

# Decimal arithmetic for health calc
rust_decimal = "1.34"

# Env, logging, errors
dotenvy = "0.15"
tracing = "0.1"
tracing-subscriber = { version = "0.3", features = ["env-filter", "json"] }
anyhow = "1.0"
thiserror = "1.0"
chrono = { version = "0.4", features = ["serde"] }
uuid = { version = "1.6", features = ["v4", "serde"] }
parking_lot = "0.12"

# State & concurrency
dashmap = "6.1"
arc-swap = "1.7"

# Cyclic ARB modules (shared lib for the in-process merged daemon — R28 Q2)
cyclic_rs = { path = "../cyclic_rs" }


[lib]
name = "liquidator_rs"
path = "src/lib.rs"
