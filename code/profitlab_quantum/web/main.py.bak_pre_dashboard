@app.get("/api/training_status")
async def get_training_status():
    # Try to read from heartbeat first (real bot state)
    hb = _read_heartbeat()
    if hb and hb.get("training_status"):
        ts = hb["training_status"]
        if ts.get("next_training"):
            return ts

    # Fallback if bot is not running or heartbeat is missing
    # Deterministic schedule: Every 2 hours (00:00, 02:00, ...)
    now_utc = datetime.now(timezone.utc)
    interval_hours = 2
    
    hours_since_midnight = now_utc.hour
    remainder = hours_since_midnight % interval_hours
    
    last_training_dt = now_utc.replace(minute=0, second=0, microsecond=0) - timedelta(hours=remainder)
    next_training_dt = last_training_dt + timedelta(hours=interval_hours)
    
    return {
        "last_training": last_training_dt.isoformat() + "Z",
        "status": "idle",
        "phase": "idle",
        "next_training": next_training_dt.isoformat() + "Z"
    }

