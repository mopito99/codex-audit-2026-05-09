# ── Module-level helpers for JSON/timestamp parsing ──────────

def _iso(ts: object) -> str:
    """Convert timestamp to ISO string safely."""
    try:
        return ts.isoformat()  # type: ignore[union-attr]
    except Exception:
        return str(ts)

def _to_obj(v: object) -> Any:
    """Safely parse a value that may be JSON str, dict, list, or None."""
    if v is None:
        return None
    if isinstance(v, (dict, list)):
        return v
    if isinstance(v, str):
        try:
            return json.loads(v)
        except ValueError:
            return v
    return v

def _to_dict(v: object) -> dict[str, Any]:
    """Like _to_obj but always returns a dict."""
    obj = _to_obj(v)
    return obj if isinstance(obj, dict) else {}


def _read_heartbeat() -> dict[str, Any] | None:
    hb_path = HB_PATH
    try:
        if os.path.exists(hb_path):
            with open(hb_path, "r") as f:
                hb = json.load(f)
                return hb if isinstance(hb, dict) else None
    except Exception:
        return None
    return None


