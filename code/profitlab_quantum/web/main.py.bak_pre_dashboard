@app.post("/api/close-position")
async def close_position(data: ClosePosition):
    db = get_db()
    try:
        symbol = data.symbol
        
        # 1. Get the position
        pos = db.execute(
            text("SELECT * FROM paper_positions WHERE symbol = :s"),
            {"s": symbol}
        ).fetchone()
        
        if not pos:
            return JSONResponse(status_code=404, content={"error": f"No position found for {symbol}"})
            
        # 2. Get current price
        # Try to get from decision_logs first
        latest_log = db.execute(
            text("SELECT features FROM decision_logs WHERE symbol = :s ORDER BY timestamp DESC LIMIT 1"),
            {"s": symbol}
        ).fetchone()
        
        current_price = None
        if latest_log and latest_log.features:
            try:
                feats = json.loads(latest_log.features) if isinstance(latest_log.features, str) else latest_log.features
                current_price = float(feats.get("close") or feats.get("last_price") or feats.get("ms_mid") or 0)
            except (ValueError, TypeError, KeyError):
                pass
        
        # Fallback: use entry price if no price found
        if not current_price or current_price <= 0:
             current_price = float(pos.entry_price)

        # 3. Calculate PnL with slippage and fees
        entry_price = float(pos.entry_price)
        qty = float(pos.qty)
        side = pos.side
        
        # Apply slippage
        slippage_pct = float(BINGX_SLIPPAGE_BPS) / 10000.0
        exit_price = current_price
        
        if side == "LONG":
            # Sell to close: price might be lower due to slippage
            exit_price = current_price * (1.0 - slippage_pct)
            pnl_usd = (exit_price - entry_price) * qty
        elif side == "SHORT":
            # Buy to close: price might be higher due to slippage
            exit_price = current_price * (1.0 + slippage_pct)
            pnl_usd = (entry_price - exit_price) * qty
        else:
            pnl_usd = 0.0

        # Apply fees (taker)
        notional_close = qty * exit_price
        
        fee_rate = float(BINGX_FEE_TAKER)
        notional_open = qty * entry_price
        fee_open = notional_open * fee_rate
        fee_close = notional_close * fee_rate
        
        pnl_net = pnl_usd - fee_open - fee_close
            
        # 4. Record trade
        db.execute(text("""
            INSERT INTO paper_trades (
                timestamp, symbol, action, price, size, margin, leverage, 
                reason, event, entry_price, exit_price, pnl_usd, sl, tp
            ) VALUES (
                NOW(), :sym, :act, :px, :sz, :marg, :lev,
                :reas, 'CLOSE', :entry, :exit, :pnl, :sl, :tp
            )
        """), {
            "sym": symbol,
            "act": side, 
            "px": exit_price,
            "sz": qty,
            "marg": pos.margin_usd,
            "lev": pos.leverage,
            "reas": "Manual Close",
            "entry": entry_price,
            "exit": exit_price,
            "pnl": pnl_net,
            "sl": pos.sl,
            "tp": pos.tp
        })
        
        # 5. Update Equity
        db.execute(text("""
            UPDATE paper_equity 
            SET balance = balance + :pnl, updated_at = NOW()
            WHERE symbol = :sym
        """), {"pnl": pnl_net, "sym": symbol})
        
        # 6. Delete position
        db.execute(text("DELETE FROM paper_positions WHERE symbol = :s"), {"s": symbol})
        
        db.commit()
        return {"status": "ok", "reason": f"Position {symbol} closed at {exit_price:.2f} (PnL: {pnl_net:.2f})"}
        
    except Exception as e:
        db.rollback()
        return JSONResponse(status_code=500, content={"error": str(e)})
    finally:
        db.close()

