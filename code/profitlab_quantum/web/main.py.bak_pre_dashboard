_LEAGUE_EMPTY = {
    "league": "ascenso", "league_name": LEAGUE_NAME_DEFAULT,
    "league_emoji": "⚽", "league_color": "yellow",
    "max_leverage": 1.0, "next_leverage": 2.0,
