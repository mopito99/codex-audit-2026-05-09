    "next_league": "silver", "requirements": "Win rate >40% y PnL positivo",
}


def _classify_league(win_rate: float, sharpe: float, drawdown: float,
                     pnl_7d: float, total_equity: float, initial_capital: float) -> dict[str, Any]:
    """Classify league tier from metrics. Returns dict with league fields."""
    if drawdown > 15 or total_equity < initial_capital * 0.85:
        return {"league": "descenso", "league_name": "Liga de Descenso", "league_emoji": "📉",
                "league_color": "red", "next_league": "ascenso", "requirements": "Reducir drawdown <15%"}
    if win_rate >= 55 and sharpe >= 1.0 and drawdown < 5:
        return {"league": "diamond", "league_name": "Liga Diamante", "league_emoji": "💎",
                "league_color": "cyan", "next_league": None, "requirements": "¡Máximo nivel!"}
    if win_rate >= 50 and sharpe >= 0.5:
        return {"league": "gold", "league_name": "Liga Oro", "league_emoji": "🥇",
                "league_color": "yellow", "next_league": "diamond",
                "requirements": "Win rate >55%, Sharpe >1.0, DD <5%"}
    if win_rate >= 40 and pnl_7d > 0:
        return {"league": "silver", "league_name": "Liga Plata", "league_emoji": "🥈",
                "league_color": "gray", "next_league": "gold",
                "requirements": "Win rate >50% y Sharpe >0.5"}
    return {"league": "ascenso", "league_name": LEAGUE_NAME_DEFAULT, "league_emoji": "⚽",
            "league_color": "yellow", "next_league": "silver",
            "requirements": "Win rate >40% y PnL positivo"}


def _calc_sharpe(pnl_list: list[float]) -> float:
    """Calculate simplified annualized Sharpe ratio."""
    if len(pnl_list) <= 1:
        return 0.0
    mean_pnl = statistics.mean(pnl_list)
    std_pnl = statistics.stdev(pnl_list) or 0.01
    return (mean_pnl / std_pnl) * (252 ** 0.5)


def _calc_league_metrics(trades: Any) -> dict[str, Any]:
    """Compute win rate, PnL, Sharpe, and counts from trade rows."""
    BE_THRESHOLD = 0.05
    wins = sum(1 for t in trades if (t.pnl_usd or 0) > BE_THRESHOLD)
    losses = sum(1 for t in trades if (t.pnl_usd or 0) < -BE_THRESHOLD)
    be_trades_7d = sum(1 for t in trades if abs(t.pnl_usd or 0) <= BE_THRESHOLD)
    total = len(trades)
    win_rate = (wins / total * 100) if total > 0 else 0
    pnl_7d = sum(t.pnl_usd or 0 for t in trades)
    sharpe = _calc_sharpe([t.pnl_usd or 0 for t in trades])
    return {
        "wins": wins, "losses": losses, "be_7d": be_trades_7d,
        "total": total, "win_rate": win_rate, "pnl_7d": pnl_7d, "sharpe": sharpe,
    }


@app.get("/api/league")
async def get_league_status():
    """
    Calcula la liga actual basada en métricas de rendimiento:
    - Descenso: Drawdown >15% o equity <90% inicial
    - Ascenso: Operando, aprendiendo (default)
    - Silver: Win rate >40% y PnL positivo
    - Gold: Win rate >50% y Sharpe >0.5
    - Diamond: Win rate >55% y Sharpe >1.0 y Drawdown <5%
    """
    db = get_db()
    try:
        trades_query = text("""
            SELECT pnl_usd, margin, timestamp
            FROM paper_trades
            WHERE event = 'CLOSE'
            AND timestamp >= NOW() - INTERVAL '7 days'
            ORDER BY timestamp ASC
        """)
        trades = db.execute(trades_query).fetchall()
        
        equity_query = text("SELECT SUM(balance) as total, SUM(peak) as peak FROM paper_equity")
        equity_row = db.execute(equity_query).fetchone()
        total_equity = float(equity_row.total or 0) if equity_row else 0
        peak_equity = float(equity_row.peak or 0) if equity_row else 0
        
        if not trades:
            # Even without CLOSE trades, still compute equity-based drawdown
            initial_capital = float(INITIAL_CAPITAL)
            drawdown = ((peak_equity - total_equity) / peak_equity * 100) if peak_equity > 0 else 0
            info = _classify_league(0.0, 0.0, drawdown, 0.0, total_equity, initial_capital)
            league = info["league"]
            max_leverage = _LEAGUE_LEVERAGE.get(league, 1.0)
            next_leverage = _LEAGUE_LEVERAGE.get(info["next_league"], max_leverage) if info["next_league"] else max_leverage
            tokens_query = text("SELECT COUNT(DISTINCT symbol) FROM paper_positions WHERE side IS NOT NULL")
            tokens_active = db.execute(tokens_query).scalar() or 0
            return {
                **info,
                "max_leverage": max_leverage,
                "next_leverage": next_leverage,
                "tokens_active": tokens_active,
                "tokens_total": len(TOKENS),
                "metrics": {"win_rate": 0, "total_trades": 0, "wins": 0, "losses": 0,
                            "be_7d": 0, "pnl_7d": 0, "drawdown": round(drawdown, 1),
                            "sharpe": 0, "equity": round(total_equity, 2)},
            }
        
        m = _calc_league_metrics(trades)
        initial_capital = float(INITIAL_CAPITAL)
        drawdown = ((peak_equity - total_equity) / peak_equity * 100) if peak_equity > 0 else 0
        
        info = _classify_league(m["win_rate"], m["sharpe"], drawdown, m["pnl_7d"], total_equity, initial_capital)
        league = info["league"]
        max_leverage = _LEAGUE_LEVERAGE.get(league, 1.0)
        next_leverage = _LEAGUE_LEVERAGE.get(info["next_league"], max_leverage) if info["next_league"] else max_leverage
        
        tokens_query = text("SELECT COUNT(DISTINCT symbol) FROM paper_positions WHERE side IS NOT NULL")
        tokens_active = db.execute(tokens_query).scalar() or 0
        
        return {
            **info,
            "max_leverage": max_leverage,
            "next_leverage": next_leverage,
            "tokens_active": tokens_active,
            "tokens_total": len(TOKENS),
            "metrics": {
                "win_rate": round(m["win_rate"], 1), "total_trades": m["total"],
                "wins": m["wins"], "losses": m["losses"], "be_7d": m["be_7d"],
                "pnl_7d": round(m["pnl_7d"], 2), "drawdown": round(drawdown, 1),
                "sharpe": round(m["sharpe"], 2), "equity": round(total_equity, 2),
            },
        }
    except Exception as e:
        print(f"Error calculating league: {e}")
        return {**_LEAGUE_EMPTY, "error": str(e)}
    finally:
        db.close()


def _enrich_risk_with_equity(risk_obj: dict[str, Any], equity_by_symbol: dict[str, Any], symbol: str) -> None:
    """Add portfolio/peak from equity map into risk_obj in-place."""
    eq = equity_by_symbol.get(str(symbol))
    if eq:
        risk_obj.setdefault("portfolio", eq.get("balance"))
        risk_obj.setdefault("peak", eq.get("peak"))


def _build_log_entry(row: Any, equity_by_symbol: dict[str, Any]) -> dict[str, Any]:
    """Build a strategy log entry dict from a decision_logs row."""
    features_obj = _to_obj(row.features)
    risk_obj = _to_dict(row.risk_metrics)
    _enrich_risk_with_equity(risk_obj, equity_by_symbol, row.symbol)
    return {
        "timestamp": _iso(row.timestamp),
        "symbol": row.symbol,
        "features": features_obj,
        "agent_probs": row.agent_probs,
        "risk_metrics": risk_obj,
    }


@app.get("/api/strategy-data")
async def get_strategy_data():
    db = get_db()
    try:
        history_window_hours = 6

        # Equity map (per symbol) from Postgres
        equity_by_symbol: dict[str, dict[str, Any]] = {}
        try:
            eq_rows = db.execute(text("SELECT symbol, balance, peak FROM paper_equity")).fetchall()
            for r in eq_rows:
                equity_by_symbol[str(r.symbol)] = {
                    "balance": float(r.balance or 0.0),
                    "peak": float(r.peak or 0.0),
                }
        except Exception:
            equity_by_symbol = {}

        # Latest log overall
        latest = db.execute(text("SELECT * FROM decision_logs ORDER BY timestamp DESC LIMIT 1")).fetchone()

        # Latest per symbol (pro view)
        latest_by_symbol_rows = db.execute(text("""
            SELECT DISTINCT ON (symbol) *
            FROM decision_logs
            WHERE timestamp >= (NOW() - (:hours || ' hours')::interval)
            ORDER BY symbol, timestamp DESC
        """), {"hours": history_window_hours}).fetchall()

        # Recent history
        history_rows = db.execute(text("""
            SELECT *
            FROM decision_logs
            WHERE timestamp >= (NOW() - (:hours || ' hours')::interval)
            ORDER BY timestamp DESC
            LIMIT 200
        """), {"hours": history_window_hours}).fetchall()

        history = [_build_log_entry(row, equity_by_symbol) for row in history_rows]
        latest_data = _build_log_entry(latest, equity_by_symbol) if latest else None
        latest_by_symbol = [_build_log_entry(row, equity_by_symbol) for row in latest_by_symbol_rows]

        return {
            "latest": latest_data,
            "latest_by_symbol": latest_by_symbol,
            "history": history,
            "window_hours": history_window_hours,
        }
    except Exception as e:
        print(f"Error fetching strategy data: {e}")
        return {"latest": None, "latest_by_symbol": [], "history": [], "window_hours": 0}
    finally:
        db.close()




def _calc_next_scan_seconds() -> int:
    """Seconds until next 5-minute candle boundary."""
    now = datetime.now(timezone.utc)
    elapsed = (now.minute % 5) * 60 + now.second
    remaining = 5 * 60 - elapsed
    return max(1, remaining)


