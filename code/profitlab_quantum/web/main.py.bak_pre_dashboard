def _calc_balance_from_pnl(db: Any) -> tuple[float, float]:
    """Calculate current balance from INITIAL_CAPITAL + realized PnL. Returns (balance, peak)."""
    try:
        pnl_query = text("SELECT SUM(pnl_usd) FROM paper_trades WHERE pnl_usd IS NOT NULL")
        total_realized_pnl = db.execute(pnl_query).scalar() or 0.0
        balance = float(INITIAL_CAPITAL) + float(total_realized_pnl)
        return balance, float(INITIAL_CAPITAL)
    except Exception as e:
        print(f"Error calculating balance from PnL: {e}")
        return float(INITIAL_CAPITAL), float(INITIAL_CAPITAL)


def _extract_price(features: dict[str, Any]) -> float:
    """Extract price from a decision_log features dict."""
    px_raw = (
        features.get("close_price")
        or features.get("close")
        or features.get("last_price")
        or features.get("ms_mid")
        or 0
    )
    return float(px_raw or 0)


def _fetch_price_data(db: Any) -> tuple[dict[str, Any], dict[str, float]]:
    """Fetch latest + previous prices from decision_logs. Returns (prices_by_symbol, current_prices)."""
    query_prices = text("""
        SELECT symbol, features, rn
        FROM (
            SELECT symbol, features,
                   row_number() OVER (PARTITION BY symbol ORDER BY timestamp DESC) AS rn
            FROM decision_logs
        ) q
        WHERE rn <= 2
        ORDER BY symbol, rn
    """)
    prices_result = db.execute(query_prices).fetchall()

    prices_by_symbol: dict[str, list[float]] = {}
    current_prices: dict[str, float] = {}

    for row in prices_result:
        try:
            features = row.features
            if isinstance(features, str):
                features = json.loads(features)
            if not isinstance(features, dict):
                continue
            px = _extract_price(features)
            if px > 0:
                prices_by_symbol.setdefault(row.symbol, []).append(px)
        except Exception:
            continue

    for sym, pxs in prices_by_symbol.items():
        if pxs:
            current_prices[sym] = float(pxs[0])

    return prices_by_symbol, current_prices


def _build_ticker(prices_by_symbol: dict[str, Any]) -> list[dict[str, Any]]:
    """Build ticker list in configured token order."""
    ticker = []
    for sym in TOKENS:
        pxs = prices_by_symbol.get(sym) or []
        if not pxs:
            continue
        last_px = float(pxs[0])
        prev_px = float(pxs[1]) if len(pxs) > 1 else None
        chg_pct = ((last_px - prev_px) / prev_px * 100.0) if prev_px and prev_px > 0 else 0.0
        ticker.append({"symbol": sym, "price": last_px, "change_pct": chg_pct})
    return ticker


def _calc_position_pnl(side: str, entry_price: float, current_price: float, qty: float) -> float:
    """Calculate unrealized PnL for a single position."""
    if side == "LONG":
        return (current_price - entry_price) * qty
    if side == "SHORT":
        return (entry_price - current_price) * qty
    return 0.0


def _build_positions(db: Any, live_prices: dict[str, Any], current_prices: dict[str, Any]) -> tuple[list[dict[str, Any]], float]:
    """Build positions list and sum unrealized PnL. Returns (positions, unrealized_pnl)."""
    query = text("SELECT * FROM paper_positions ORDER BY open_time DESC")
    pos_result = db.execute(query).fetchall()
    positions = []
    unrealized_pnl = 0.0

    for row in pos_result:
        symbol = row.symbol
        entry_price = float(row.entry_price)
        side = str(row.side)
        notional_usd = float(row.notional_usd)
        raw_qty = getattr(row, "qty", None)
        if raw_qty is not None:
            qty = float(raw_qty)
        elif entry_price:
            qty = notional_usd / entry_price
        else:
            qty = 0.0
        margin_usd = float(row.margin_usd) if getattr(row, "margin_usd", None) is not None else 0.0
        lev = float(row.leverage) if getattr(row, "leverage", None) is not None else 1.0
        sl = float(row.sl) if getattr(row, "sl", None) is not None else None
        tp = float(row.tp) if getattr(row, "tp", None) is not None else None
        current_price = live_prices.get(symbol) or current_prices.get(symbol) or entry_price

        pnl_usd = _calc_position_pnl(side, entry_price, current_price, qty)
        unrealized_pnl += pnl_usd

        positions.append({
            "symbol": symbol, "direction": side, "qty": qty,
            "margin": round(float(margin_usd), 2), "leverage": round(float(lev), 1),
            "entry": entry_price, "current": current_price,
            "pnl": round(float(pnl_usd), 2),
            "sl": sl, "tp1": tp, "tp2": None, "tp3": None,
            "open_time": str(row.open_time),
        })

    return positions, unrealized_pnl


def _build_trades_list(db: Any) -> list[dict[str, Any]]:
    """Fetch recent trade history from paper_trades."""
    query = text("SELECT * FROM paper_trades ORDER BY timestamp DESC LIMIT 500")
    trades_db = db.execute(query).fetchall()
    trades = []
    for t in trades_db:
        trades.append({
            "close_time": str(t.timestamp),
            "symbol": t.symbol,
            "side": t.action,
            "entry": float(getattr(t, "entry_price", None) or (t.price or 0.0)),
            "exit": float(getattr(t, "exit_price", None) or 0.0),
            "pnl": float(getattr(t, "pnl_usd", None) or 0.0),
            "event": str(getattr(t, "event", "") or ""),
            "reason": str(getattr(t, "reason", "") or ""),
            "leverage": float(getattr(t, "leverage", 1) or 1),
            "sl": float(getattr(t, "sl", 0) or 0),
            "tp": float(getattr(t, "tp", 0) or 0),
        })
    return trades


def _calc_trade_stats(trades_list: list[dict[str, Any]]) -> dict[str, Any]:
    """Compute win/loss/BE stats from trades list. Returns stats dict."""
    BE_THRESHOLD = 0.05
    close_events = [t for t in trades_list if t.get('event') == 'CLOSE']
    tp1_events = [t for t in trades_list if t.get('event') == 'TP1']

    # Build TP1 PnL lookup
    tp1_pnl_map: dict[tuple[str, float], float] = {}
    for tp1 in tp1_events:
        key = (tp1['symbol'], round(tp1['entry'], 8))
        tp1_pnl_map[key] = tp1_pnl_map.get(key, 0.0) + tp1['pnl']

    # Each CLOSE = one trade; total PnL includes TP1 partials
    trade_pnls = []
    for c in close_events:
        key = (c['symbol'], round(c['entry'], 8))
        trade_pnls.append(c['pnl'] + tp1_pnl_map.get(key, 0.0))

    total_trades = len(close_events)
    win_count = sum(1 for p in trade_pnls if p > BE_THRESHOLD)
    loss_count = sum(1 for p in trade_pnls if p < -BE_THRESHOLD)
    be_count = sum(1 for p in trade_pnls if abs(p) <= BE_THRESHOLD)
    win_rate = (win_count / total_trades * 100.0) if total_trades > 0 else 0.0
    total_pnl_abs = sum(trade_pnls)
    pnl_pct = (total_pnl_abs / float(INITIAL_CAPITAL)) * 100.0

    return {
        "total_trades": total_trades, "win_count": win_count,
        "loss_count": loss_count, "be_count": be_count,
        "win_rate": win_rate, "pnl_pct": pnl_pct,
    }


def _parse_features(raw: Any) -> dict[str, Any]:
    """Safely parse features column (str or dict)."""
    if isinstance(raw, str):
        try:
            return json.loads(raw)
        except ValueError:
            return {}
    return raw if isinstance(raw, dict) else {}


def _parse_probs(raw: Any) -> list[Any]:
    """Safely parse agent_probs column (str or list)."""
    if isinstance(raw, str):
        try:
            return json.loads(raw)
        except ValueError:
            return []
    return raw if isinstance(raw, list) else []


def _build_decisions(db: Any) -> list[dict[str, Any]]:
    """Fetch latest AI decisions per symbol."""
    try:
        query = text("""
            SELECT DISTINCT ON (symbol) 
                id, timestamp, symbol, features, agent_probs
            FROM decision_logs
            ORDER BY symbol, timestamp DESC
        """)
        rows = db.execute(query).fetchall()
        decisions = []
        for row in rows:
            feats = _parse_features(row.features)
            probs = _parse_probs(row.agent_probs)
            decisions.append({
                "ts": row.timestamp.isoformat() if hasattr(row.timestamp, 'isoformat') else str(row.timestamp),
                "symbol": row.symbol,
                "recommendation": feats.get("recommendation", "HOLD"),
                "price": _extract_price(feats),
                "confidence": float(feats.get("confidence", 0)),
                "agent_probs": [float(p) for p in probs] if probs else [],
            })
        return decisions
    except Exception as e:
        print(f"Error fetching decisions: {e}")
        return []


def _build_equity_curve(db: Any) -> list[dict[str, Any]]:
    """Derive equity curve from realized CLOSE PnL."""
    try:
        eq_rows = db.execute(text("""
            SELECT timestamp, pnl_usd
            FROM paper_trades
            WHERE COALESCE(event,'') = 'CLOSE'
            ORDER BY timestamp DESC
            LIMIT 500
        """)).fetchall()
        eq_rows = list(reversed(eq_rows))
        eq = float(INITIAL_CAPITAL)
        peak = eq
        curve = []
        for r in eq_rows:
            eq += float(getattr(r, "pnl_usd", 0.0) or 0.0)
            peak = max(peak, eq)
            dd = (max(0.0, (peak - eq) / peak) * 100.0) if peak > 0 else 0.0
            ts_str = r.timestamp.isoformat() if hasattr(r.timestamp, 'isoformat') else str(r.timestamp)
            curve.append({"ts": ts_str, "equity": round(eq, 2), "dd": round(dd, 4)})
        return curve
    except Exception:
        return []


def _read_market_status_from_hb() -> dict[str, Any]:
    """Read market status from heartbeat file."""
    defaults = {
        "trading_mode": "full", "is_cme_weekend": False,
        "is_us_holiday": False, "is_europe_holiday": False,
        "event_risk_active": False, "event_risk_stars": 0,
        "event_risk_event": "", "event_risk_minutes_to": 0,
        "event_risk_timestamp": 0, "position_multiplier": 1.0,
    }
    try:
        if os.path.exists(HB_PATH):
            with open(HB_PATH, "r") as f:
                hb = json.load(f)
                ms = hb.get("market_status")
                if isinstance(ms, dict) and ms:
                    return ms
    except Exception:
        pass
    return defaults

@app.get("/api/stats")
async def get_stats():
    db = get_db()
    positions = []
    trades_list = []
    equity_history = []
    current_balance = 0.0
    unrealized_pnl = 0.0
    peak_equity = 0.0
    ticker = []
    stats: dict[str, Any] = {"total_trades": 0, "win_count": 0, "loss_count": 0, "be_count": 0, "win_rate": 0.0, "pnl_pct": 0.0}

    try:
        # 0. Balance from realized PnL
        current_balance, peak_equity = _calc_balance_from_pnl(db)

        # 1. Price data + ticker
        prices_by_symbol, current_prices = _fetch_price_data(db)
        ticker = _build_ticker(prices_by_symbol)

        # Live prices (BingX → heartbeat fallback)
        live_prices = await _fetch_bingx_prices()
        if not live_prices:
            hb = _read_heartbeat()
            if hb and "live_prices" in hb:
                live_prices = hb["live_prices"]

        # 2. Positions
        positions, unrealized_pnl = _build_positions(db, live_prices or {}, current_prices)

        # 3. Trades + stats
        trades_list = _build_trades_list(db)
        stats = _calc_trade_stats(trades_list)

        # 3b. AI decisions
        decisions_list = _build_decisions(db)

        # 4. Equity curve
        equity_history = _build_equity_curve(db)

    except Exception as e:
        print(f"Error in get_stats: {e}")
        decisions_list = []
    finally:
        db.close()

    equity_now = float(current_balance) + float(unrealized_pnl)
    if peak_equity <= 0:
        peak_equity = max(float(INITIAL_CAPITAL), equity_now)
    drawdown = max(0.0, (peak_equity - equity_now) / peak_equity) * 100.0 if peak_equity > 0 else 0.0

    if not equity_history:
        equity_history = [{"ts": datetime.now(timezone.utc).isoformat(), "equity": round(equity_now, 2), "dd": round(drawdown, 4)}]

    return {
        "model_version": "Version 3.0 IA Neuro",
        "market_status": _read_market_status_from_hb(),
        "equity": {
            "balance": current_balance, "equity": equity_now,
            "unrealized": round(unrealized_pnl, 2), "drawdown": round(drawdown, 2),
        },
        "stats": {
            "pnl_pct": round(stats["pnl_pct"], 2),
            "total_trades": stats["total_trades"],
            "win_rate": round(stats["win_rate"], 1),
            "winning": stats["win_count"],
            "losing": stats["loss_count"],
            "be_count": stats["be_count"],
        },
        "trading_window": {
            "enabled": True, "is_open": True, "reason": "24/7 Quantum",
            "local_time": datetime.now(timezone.utc).strftime("%H:%M"), "tz": "UTC",
        },
        "next_scan_seconds": _calc_next_scan_seconds(),
        "ticker": ticker,
        "positions": positions,
        "decisions": decisions_list,
        "trades": trades_list,
        "equity_history": equity_history,
    }

