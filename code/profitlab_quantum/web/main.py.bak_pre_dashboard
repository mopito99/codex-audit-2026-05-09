# ── Real-time BingX price cache ──────────────────────────────

_RT_PRICE_CACHE: dict[str, Any] = {}
_RT_PRICE_TS: float = 0.0
_RT_CACHE_TTL: float = 5.0   # refresh at most every 5 seconds

_BINGX_TICKERS_URL = "https://open-api.bingx.com/openApi/swap/v2/quote/ticker"
# Use all configured tokens for live prices (not a static subset)
_DASH_SYMBOLS = list(TOKENS) if TOKENS else [
    "BTC-USDT", "ETH-USDT", "SOL-USDT", "BNB-USDT", "XRP-USDT",
    "ADA-USDT", "DOGE-USDT", "TRX-USDT", "BCH-USDT", "HYPE-USDT",
    "XAUT-USDT", "LINK-USDT", "XMR-USDT", "XLM-USDT", "HBAR-USDT", "LTC-USDT",
]

async def _fetch_single_bingx_price(session: Any, sym: str) -> tuple[str, float | None]:
    """Fetch price for a single symbol from BingX. Returns (symbol, price_or_None)."""
    try:
        async with session.get(
            _BINGX_TICKERS_URL,
            params={"symbol": sym},
            timeout=_aiohttp.ClientTimeout(total=3),
        ) as resp:
            if resp.status == 200:
                d = await resp.json()
                if "data" in d and d["data"]:
                    lp = d["data"].get("lastPrice")
                    if lp:
                        return sym, float(lp)
    except Exception:
        pass
    return sym, None


async def _fetch_bingx_prices() -> dict[str, Any]:
    """Fetch latest prices from BingX public ticker API (no auth needed)."""
    global _RT_PRICE_CACHE, _RT_PRICE_TS
    now = _time.time()
    if now - _RT_PRICE_TS < _RT_CACHE_TTL and _RT_PRICE_CACHE:
        return _RT_PRICE_CACHE
    try:
        prices = {}
        async with _aiohttp.ClientSession() as session:
            for sym in _DASH_SYMBOLS:
                sym_key, px = await _fetch_single_bingx_price(session, sym)
                if px is not None:
                    prices[sym_key] = px
        if prices:
            _RT_PRICE_CACHE = prices  # type: ignore[reportConstantRedefinition]
            _RT_PRICE_TS = now  # type: ignore[reportConstantRedefinition]
        return _RT_PRICE_CACHE
    except Exception:
        return _RT_PRICE_CACHE or {}


