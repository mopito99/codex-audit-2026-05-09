        function updateTrainingCountdown() {
            if (!lastTrainingTime) return;
            
            const now = new Date();
            const nextTraining = nextTrainingTime || new Date(lastTrainingTime.getTime() + TRAINING_INTERVAL_MS);
            const remaining = nextTraining - now;
            const elapsed = now - lastTrainingTime;
            // Bar FILLS UP as we get closer to training (0% = just trained, 100% = about to train)
            const denom = trainingIntervalMs || TRAINING_INTERVAL_MS;
            const progress = Math.min(100, Math.max(0, (elapsed / denom) * 100));

            const remainingSafe = Math.max(0, remaining);
            const hours = Math.floor(remainingSafe / 3600000);
            const mins = Math.floor((remainingSafe % 3600000) / 60000);
            // const secs = Math.floor((remainingSafe % 60000) / 1000);
            const timeStr = hours > 0
                ? `${hours}h ${mins}m`
                : `${mins}m`;
            const countdownLabel = `${timeStr}`;

            let activeState = 'waiting';
            
            // Check for Dreaming state (04:00 UTC)
            const h = now.getUTCHours();
            if (h === 4) {
                activeState = 'dreaming';
            } else if (trainingStatus === 'running') {
                if (trainingPhase === 'learning') activeState = 'learning';
                else if (trainingPhase === 'training') activeState = 'training';
                else activeState = 'training';
            } else {
                // Waiting
                activeState = 'waiting';
            }
            
            // Force waiting if status is explicitly idle
            if (trainingStatus === 'idle') {
                activeState = 'waiting';
            }

            setTrainButtons(activeState, countdownLabel);
            
            // Debug info
            const debugEl = document.getElementById('debugStatus');
            if (debugEl) {
                debugEl.textContent = `Status: ${trainingStatus} | Phase: ${trainingPhase} | Active: ${activeState}`;
            }

            // Refresh training status shortly after cycle boundary (debounced)
            if (remaining <= 0 && remaining > -60000 && trainingStatus !== 'running' && !window._trainFetchPending) {
                window._trainFetchPending = true;
                setTimeout(() => { fetchTrainingStatus(); window._trainFetchPending = false; }, 15000);
            }
        }
        
        // Initial fetch and then update every 30s
        fetchTrainingStatus();
        setInterval(fetchTrainingStatus, 30000);
        
        // ============ WEEKEND COUNTDOWN ============
        function updateWeekendCountdown() {
            const countdownEl = document.getElementById('weekendCountdown');
            if (!countdownEl) return;
            
            // Get current time in Chicago (CME timezone)
            const now = new Date();
            const chicagoTime = new Date(now.toLocaleString('en-US', { timeZone: 'America/Chicago' }));
            const dayOfWeek = chicagoTime.getDay();
            const hours = chicagoTime.getHours();
            const minutes = chicagoTime.getMinutes();
            const seconds = chicagoTime.getSeconds();
            
            // CME closes Friday 4pm CT, opens Sunday 5pm CT
            // Weekend = Saturday all day, Sunday until 5pm, Friday after 4pm
            
            const isWeekend = (dayOfWeek === 6) || 
                              (dayOfWeek === 0 && hours < 17) || 
                              (dayOfWeek === 5 && hours >= 16);
            
            if (isWeekend) {
                // Calculate time until market opens (Sunday 5pm CT)
                let hoursUntilOpen;
                if (dayOfWeek === 5 && hours >= 16) {
                    // Friday after close: ~49 hours until Sunday 5pm
                    hoursUntilOpen = (24 - hours - 1) + 24 + 17; // Rest of Friday + Saturday + Sunday until 5pm
                    const minsLeft = 60 - minutes;
                    hoursUntilOpen += minsLeft / 60;
                } else if (dayOfWeek === 6) {
                    // Saturday: 24 + 17 hours until Sunday 5pm
                    hoursUntilOpen = (24 - hours) + 17 - minutes/60;
                } else {
                    // Sunday before 5pm
                    hoursUntilOpen = 17 - hours - minutes/60;
                }
                
                const h = Math.floor(hoursUntilOpen);
                const m = Math.floor((hoursUntilOpen - h) * 60);
                countdownEl.textContent = `📈 Abre en ${h}h ${m}m`;
                countdownEl.style.color = '#10B981';
            } else {
                // Calculate time until weekend (Friday 4pm CT)
                let hoursUntilClose;
                const daysUntilFriday = (5 - dayOfWeek + 7) % 7;
                
                if (daysUntilFriday === 0) {
                    // It's Friday, before 4pm
                    hoursUntilClose = 16 - hours - minutes/60;
                } else {
                    hoursUntilClose = daysUntilFriday * 24 + (16 - hours) - minutes/60;
                }
                
                if (hoursUntilClose < 0) hoursUntilClose = 0;
                
                const h = Math.floor(hoursUntilClose);
                const m = Math.floor((hoursUntilClose - h) * 60);
                
                if (h < 24) {
                    countdownEl.textContent = `⏱️ Cierra en ${h}h ${m}m`;
                    countdownEl.style.color = '#F59E0B';
                } else {
                    const days = Math.floor(h / 24);
                    const remainingHours = h % 24;
                    countdownEl.textContent = `⏱️ ${days}d ${remainingHours}h`;
                    countdownEl.style.color = '#9CA3AF';
                }
            }
        }

        // Update training countdown every second
        updateTrainingCountdown();
        setInterval(updateTrainingCountdown, 1000);

