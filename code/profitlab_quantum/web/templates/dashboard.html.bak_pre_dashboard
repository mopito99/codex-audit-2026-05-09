                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } },
                        scales: {
                            x: { grid: { display: false }, ticks: { color: '#9CA3AF', font: { size: 9 } } },
                            y: { grid: { color: '#374151' }, ticks: { color: '#9CA3AF' } }
