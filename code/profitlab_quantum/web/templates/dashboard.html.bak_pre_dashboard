            const ctx = document.getElementById('tradesBySymbolChart').getContext('2d');
            const symbols = Object.keys(symbolTrades);
            const values = symbols.map(s => symbolTrades[s]);
            
            if (charts.tradesBySymbol) {
                charts.tradesBySymbol.data.labels = symbols;
                charts.tradesBySymbol.data.datasets[0].data = values;
                charts.tradesBySymbol.update('none');
