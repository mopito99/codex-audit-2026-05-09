            const ctx = document.getElementById('winLossChart').getContext('2d');
            be = be || 0;
            
            if (charts.winLoss) {
                charts.winLoss.data.datasets[0].data = [wins, losses, be];
                charts.winLoss.update('none');
            } else {
                charts.winLoss = new Chart(ctx, {
                    type: 'doughnut',
                    data: {
                        labels: ['Wins', 'Losses', 'BE'],
                        datasets: [{
                            data: [wins, losses, be],
                            backgroundColor: ['#10B981', '#EF4444', '#3B82F6'],
                            borderWidth: 0,
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { 
                            legend: { display: true, position: 'bottom', labels: { color: '#9CA3AF', boxWidth: 12 } }
                        },
                        cutout: '60%',
                    }
                });
            }
        }

        function updateActionsChart() {
            const ctx = document.getElementById('actionsChart').getContext('2d');
            
            if (charts.actions) {
                charts.actions.data.datasets[0].data = [actionCounts.HOLD, actionCounts.LONG, actionCounts.SHORT, actionCounts.CLOSE];
                charts.actions.update('none');
            } else {
                charts.actions = new Chart(ctx, {
                    type: 'doughnut',
                    data: {
                        labels: ['HOLD', 'LONG', 'SHORT', 'CLOSE'],
                        datasets: [{
                            data: [actionCounts.HOLD, actionCounts.LONG, actionCounts.SHORT, actionCounts.CLOSE],
                            backgroundColor: ['#6B7280', '#10B981', '#EF4444', '#F59E0B'],
                            borderWidth: 0,
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { 
                            legend: { display: true, position: 'bottom', labels: { color: '#9CA3AF', boxWidth: 12, font: { size: 10 } } }
                        },
                        cutout: '60%',
                    }
                });
            }
        }

        function updatePnLBySymbolChart() {
            const ctx = document.getElementById('pnlBySymbolChart').getContext('2d');
            const symbols = Object.keys(symbolPnL);
            const values = symbols.map(s => symbolPnL[s]);
            const colors = values.map(v => v >= 0 ? '#10B981' : '#EF4444');
            
            if (charts.pnlBySymbol) {
                charts.pnlBySymbol.data.labels = symbols;
                charts.pnlBySymbol.data.datasets[0].data = values;
                charts.pnlBySymbol.data.datasets[0].backgroundColor = colors;
                charts.pnlBySymbol.update('none');
            } else {
                charts.pnlBySymbol = new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: symbols.length ? symbols : [],
                        datasets: [{
                            data: values.length ? values : [],
                            backgroundColor: colors.length ? colors : '#374151',
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } },
                        scales: {
                            x: { grid: { display: false }, ticks: { color: '#9CA3AF', font: { size: 9 } } },
                            y: { grid: { color: '#374151' }, ticks: { color: '#9CA3AF', callback: v => '$' + Number(v).toFixed(2) } }
                        }
                    }
                });
            }
        }

