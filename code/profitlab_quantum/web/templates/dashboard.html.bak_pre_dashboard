    <script>
        function decimalsForPrice(value) {
            if (value === null || value === undefined || !isFinite(value)) return 2;
            const abs = Math.abs(value);
            if (abs >= 1000) return 2;
            if (abs >= 100) return 2;
            if (abs >= 10) return 3;
            if (abs >= 1) return 4;
            if (abs >= 0.1) return 5;
            if (abs >= 0.01) return 6;
            return 8;
        }

        function fmtPrice(value) {
            if (value === null || value === undefined || !isFinite(value)) return '-';
            return '$' + Number(value).toFixed(decimalsForPrice(Number(value)));
        }

        function decimalsForQty(value) {
            if (value === null || value === undefined || !isFinite(value)) return 4;
            const abs = Math.abs(value);
            if (abs >= 1) return 4;
            if (abs >= 0.1) return 5;
            return 6;
        }

        function fmtQty(value) {
            if (value === null || value === undefined || !isFinite(value)) return '-';
            return Number(value).toFixed(decimalsForQty(Number(value)));
        }

        // Chart instances
        let charts = {
            equity: null,
            drawdown: null,
            winLoss: null,
            actions: null,
            pnlBySymbol: null,
            tradesBySymbol: null
        };

        // Action counts for chart
        let actionCounts = { HOLD: 0, LONG: 0, SHORT: 0, CLOSE: 0 };
        let symbolPnL = {};
        let symbolTrades = {};
        
        // Sorting state
        let allTrades = [];
        let tradeSort = { col: 'time', dir: 'desc' };

        function sortTrades(col) {
            if (tradeSort.col === col) {
                tradeSort.dir = tradeSort.dir === 'asc' ? 'desc' : 'asc';
            } else {
                tradeSort.col = col;
                tradeSort.dir = 'desc'; // Default desc for most metrics
                if (col === 'symbol' || col === 'side') tradeSort.dir = 'asc';
            }
            renderTradesTable();
        }

        function renderTradesTable() {
            const tbody = document.getElementById('tradesTable');
            const headers = document.querySelectorAll('#tradesTableHead th');
            
            // Update header icons
            headers.forEach(th => {
                const col = th.dataset.col;
                const iconSpan = th.querySelector('.sort-icon');
                if (iconSpan) {
                    if (col === tradeSort.col) {
                        iconSpan.textContent = tradeSort.dir === 'asc' ? ' ▲' : ' ▼';
                        th.classList.add('text-white');
                    } else {
                        iconSpan.textContent = '';
                        th.classList.remove('text-white');
                    }
                }
            });

            let sorted = [...allTrades];
            sorted.sort((a, b) => {
                let valA, valB;
                switch (tradeSort.col) {
                    case 'time': 
                        valA = new Date(a.close_time || a.open_time || 0).getTime(); 
                        valB = new Date(b.close_time || b.open_time || 0).getTime(); 
                        break;
                    case 'symbol': valA = a.symbol || ''; valB = b.symbol || ''; break;
                    case 'side': valA = a.side || ''; valB = b.side || ''; break;
                    case 'pnl': valA = a.pnl || -999999; valB = b.pnl || -999999; break;
                    default: return 0;
                }
                
                if (valA < valB) return tradeSort.dir === 'asc' ? -1 : 1;
                if (valA > valB) return tradeSort.dir === 'asc' ? 1 : -1;
                return 0;
            });

            if (sorted.length === 0) {
                tbody.innerHTML = '<tr><td colspan="7" class="p-4 text-center text-gray-500">No trades yet</td></tr>';
            } else {
                tbody.innerHTML = sorted.map(t => {
                    const pnl = t.pnl || 0;
                    const pnlColor = pnl >= 0 ? '#10B981' : '#EF4444';
                    const pnlText = t.pnl !== null && t.pnl !== undefined ? (pnl >= 0 ? '+$' : '-$') + Math.abs(pnl).toFixed(2) : '-';
                    const evt = t.event || '—';
                    const evtColor = evt === 'CLOSE' ? 'text-orange-400' : evt === 'OPEN' ? 'text-green-400' : evt === 'BE' ? 'text-blue-400' : evt === 'MANUAL' ? 'text-yellow-300' : 'text-gray-500';
                    const src = '<span class="text-xs font-bold ' + evtColor + '">' + evt + '</span>';
                    return `
                    <tr class="border-t border-gray-700 hover:bg-gray-750" data-pos-symbol="${t.symbol}">
                        <td class="p-2 text-xs text-gray-400">${t.close_time ? new Date(t.close_time).toLocaleTimeString() : '-'}</td>
                        <td class="p-2 font-mono">${t.symbol}</td>
                        <td class="p-2 text-center">${src}</td>
                        <td class="p-2 text-center ${t.side === 'LONG' ? 'text-green-400' : 'text-red-400'} font-bold">${t.side === 'LONG' ? '🟢' : '🔴'} ${t.side}</td>
                        <td class="p-2 text-right">${fmtPrice(t.entry)}</td>
                        <td class="p-2 text-right">${fmtPrice(t.exit)}</td>
                        <td class="p-2 text-right font-bold" style="color: ${pnlColor}">${pnlText}</td>
                    </tr>
                `}).join('');
            }
        }

        // Countdown timer
        let countdownInterval = null;
        let countdownSeconds = 0;

        function startCountdown(seconds) {
            countdownSeconds = seconds;
            if (countdownInterval) clearInterval(countdownInterval);
            updateCountdownDisplay();
            countdownInterval = setInterval(() => {
                countdownSeconds--;
                if (countdownSeconds <= 0) {
                    countdownSeconds = 0;
                    clearInterval(countdownInterval);
                    // Refresh data when scan should happen
                    setTimeout(fetchData, 5000);
                }
                updateCountdownDisplay();
            }, 1000);
        }

        function updateCountdownDisplay() {
            const mins = Math.floor(countdownSeconds / 60);
            const secs = countdownSeconds % 60;
            const el = document.getElementById('nextScan');
            if (!el) return;
            if (countdownSeconds <= 0) {
                el.innerHTML = '🔄 <span class="text-green-400">Scanning...</span>';
            } else if (countdownSeconds <= 60) {
                el.innerHTML = `⏱️ Next scan: <span class="text-yellow-400 font-bold">${secs}s</span>`;
            } else {
                el.innerHTML = `⏱️ Next scan: <span class="text-blue-400">${mins}m ${secs.toString().padStart(2,'0')}s</span>`;
            }
        }

        async function fetchData() {
            try {
                const resp = await fetch(`/api/stats?_=${Date.now()}`, { cache: 'no-store' });
                if (!resp.ok) {
                    const errText = await resp.text().catch(() => 'unknown');
                    console.error('API returned', resp.status, errText);
                    var bar = document.getElementById('jsDebugBar');
                    if (bar) { bar.style.display = 'block'; bar.textContent = 'API_ERR ' + resp.status + ': ' + errText.substring(0, 100); }
                    return;
                }
                const text = await resp.text();
                let data;
                try {
                    data = JSON.parse(text);
                } catch (parseErr) {
                    console.error('JSON parse error:', parseErr, 'Response:', text.substring(0, 200));
                    var bar = document.getElementById('jsDebugBar');
                    if (bar) { bar.style.display = 'block'; bar.textContent = 'JSON_ERR: ' + text.substring(0, 150); }
                    return;
                }
                try {
                    updateUI(data);
                } catch (uiErr) {
                    console.error('updateUI error:', uiErr);
                    var bar = document.getElementById('jsDebugBar');
                    if (bar) { bar.style.display = 'block'; bar.textContent = 'UI_ERR: ' + uiErr.message + ' at ' + (uiErr.stack || '').split('\n')[1]; }
                    // Still try to update balance
                    try {
                        var bEl = document.getElementById('balance');
                        if (bEl && data.equity) bEl.textContent = '$' + data.equity.balance.toFixed(0);
                    } catch(e2) {}
                }
                // Hide debug bar on success
                var bar = document.getElementById('jsDebugBar');
                if (bar && !window._dbgErrors?.length) bar.style.display = 'none';
            } catch (e) {
                console.error('Fetch error:', e);
                var bar = document.getElementById('jsDebugBar');
                if (bar) { bar.style.display = 'block'; bar.textContent = 'FETCH_ERR: ' + (e.message || e); }
            }
        }

        // Initial loads
        updateFearGreed();
        setInterval(updateFearGreed, 10 * 60 * 1000);

        async function closePosition(symbol) {
            if (!confirm(`Are you sure you want to close ${symbol}?`)) return;
            
            try {
                const resp = await fetch('/api/close-position', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ symbol: symbol })
                });
                const data = await resp.json();
                if (data.status === 'ok') {
                    // alert('Closed ' + symbol);
                    fetchData(); // Refresh immediately
                } else {
                    alert('Error closing: ' + (data.reason || 'Unknown error'));
                }
            } catch (e) {
                alert('Network error: ' + e);
            }
        }

        function renderTradingWindow(tw) {
            const badge = document.getElementById('scheduleBadge');
            if (!badge) return;
            
            if (tw.enabled) {
                badge.textContent = tw.is_open ? "OPEN" : "CLOSED";
                badge.className = tw.is_open 
                    ? "px-3 py-1 rounded-full text-xs font-semibold bg-green-900/30 border border-green-600 text-green-400"
                    : "px-3 py-1 rounded-full text-xs font-semibold bg-red-900/30 border border-red-600 text-red-400";
            } else {
                badge.textContent = "DISABLED";
                badge.className = "px-3 py-1 rounded-full text-xs font-semibold bg-gray-700/30 border border-gray-600 text-gray-300";
            }
        }

        function updateUI(data) {
            console.log("[DBG] updateUI called, data keys:", Object.keys(data));
            console.log("[DBG] balance:", data.equity?.balance, "trades:", data.stats?.total_trades);
            // Model version
            if (data.model_version) {
                document.getElementById('modelVersion').textContent = 'Model: ' + data.model_version;
            }

            // Metaverse Status (New)
            const metaEl = document.getElementById('metaverseStatus');
            if (metaEl) {
                // We can infer metaverse status from time or add a field in API later.
                // For now, let's assume "Dreaming" if between 04:00 and 05:00 UTC, else "Awake"
                const now = new Date();
                const h = now.getUTCHours();
                const isDreaming = (h === 4); // 04:00-04:59 UTC
                
                if (isDreaming) {
                    metaEl.innerHTML = '🔮 <span class="text-pink-400 font-bold animate-pulse">DREAMING</span>';
                    metaEl.title = "Training TimeGAN & Generating Scenarios";
                } else {
                    metaEl.innerHTML = '👁️ <span class="text-blue-400">AWAKE</span>';
                    metaEl.title = "Trading Live Markets";
                }
            }
            
            // V13 SMART: Update trading mode from API
            if (data.market_status) {
                const ms = data.market_status;
                const modeEl = document.getElementById('tradingMode');
                if (modeEl) {
                    const modeText = ms.trading_mode.toUpperCase().replace('_', ' ');
                    modeEl.textContent = modeText + (ms.is_cme_weekend ? ' (CME CLOSED)' : '');
                    
                    // Update badge color based on mode
                    if (ms.trading_mode === 'full') {
                        modeEl.className = 'mode-badge full';
                    } else if (ms.trading_mode === 'conservative') {
                        modeEl.className = 'mode-badge conservative';
                    } else if (ms.trading_mode === 'weekend' || ms.is_cme_weekend) {
                        modeEl.className = 'mode-badge weekend';
                    } else if (ms.trading_mode === 'pause') {
                        modeEl.className = 'mode-badge holiday';
                    } else {
                        modeEl.className = 'mode-badge weekend';
                    }
                }

                // Update Market Status Text in the new box
                const statusTextEl = document.getElementById('marketStatusText');
                if (statusTextEl) {
                    let statusMsg = ms.trading_mode.toUpperCase();
                    if (ms.is_us_holiday) statusMsg = "US HOLIDAY (" + statusMsg + ")";
                    else if (ms.is_europe_holiday) statusMsg = "EU HOLIDAY (" + statusMsg + ")";
                    else if (ms.is_cme_weekend) statusMsg = "CME CLOSED (" + statusMsg + ")";
                    
                    statusTextEl.textContent = statusMsg;
                    
                    // Color coding
                    if (ms.trading_mode === 'full' || ms.trading_mode === 'normal') {
                        statusTextEl.className = 'font-bold text-green-400 mt-1';
                    } else if (ms.trading_mode === 'pause') {
                        statusTextEl.className = 'font-bold text-red-400 mt-1';
                    } else {
                        statusTextEl.className = 'font-bold text-yellow-400 mt-1';
                    }
                }

                // Status Banner Logic (Inside LuxAlgo Banner)
                const luxMsg = document.getElementById('luxAlgoStatusMsg_v2');
                const luxBanner = document.getElementById('luxAlgoBanner');
                
                if (luxMsg) {
                    let showMsg = false;
                    let msgClass = '';
                    let msgHtml = '';
                    let bannerBorderClass = 'border-pink-600/50'; // default

                    if (ms.is_us_holiday) {
                        showMsg = true;
                        msgClass = 'bg-purple-900/80 border-purple-500 text-purple-100 border';
                        const d = new Date();
                        if (d.getMonth() === 11 && d.getDate() === 24) {
                            msgHtml = '\\uD83C\\uDF84 US Holiday Mode (Early Close: 13:00 ET)';
                        } else {
                            msgHtml = '\\uD83C\\uDF84 US Holiday Mode Active (All Day)';
                        }
                        bannerBorderClass = 'border-purple-500';
                    } else if (ms.is_cme_weekend) {
                        showMsg = true;
                        msgClass = 'bg-blue-900/80 border-blue-500 text-blue-100 border';
                        msgHtml = '💤 Weekend Mode (CME Closed • Fri 22:00 - Sun 23:00 UTC)';
                        bannerBorderClass = 'border-blue-500';
                    }

                    if (showMsg) {
                        luxMsg.className = `text-xs font-bold px-3 py-1 rounded mx-2 text-center ${msgClass}`;
                        luxMsg.innerHTML = msgHtml;
                        luxMsg.classList.remove('hidden');
                        
                        // Update banner border color if needed
                        if (luxBanner) {
                            luxBanner.className = `bg-pink-900/30 border ${bannerBorderClass} rounded-lg p-3 mb-6`;
                        }
                    } else {
                        luxMsg.classList.add('hidden');
                        // Reset banner border
                        if (luxBanner) {
                            luxBanner.className = `bg-pink-900/30 border border-pink-600/50 rounded-lg p-3 mb-6`;
                        }
                    }
                }


                // If we're on a non-dashboard page (e.g. /strategy), stop here after updating header/status.
                // The rest of the dashboard UI expects many elements that won't exist in other templates.
                const balanceEl = document.getElementById('balance');
                if (!balanceEl) {
                    const lastUpdateEl = document.getElementById('lastUpdate');
                    if (lastUpdateEl) lastUpdateEl.textContent = 'Updated: ' + new Date().toLocaleTimeString();

                    if (data.next_scan_seconds !== undefined && document.getElementById('nextScan')) {
                        startCountdown(data.next_scan_seconds);
                    }
                    return;
                }
                // Event Risk: Económico / Político (top-right)
                const econBox = document.getElementById('eventRiskEconomicBox');
                const econTitle = document.getElementById('eventRiskEconomicTitle');
                const econText = document.getElementById('eventRiskEconomicText');
                const polBox = document.getElementById('eventRiskPoliticalBox');
                const polTitle = document.getElementById('eventRiskPoliticalTitle');
                const polText = document.getElementById('eventRiskPoliticalText');
                if (econBox && econText && polBox && polText) {
                    const active = !!ms.event_risk_active;
                    const stars = ms.event_risk_stars || 0;
                    const ev = ms.event_risk_event || '';
                    const minutesTo = Number(ms.event_risk_minutes_to || 0);
                    const timestamp = Number(ms.event_risk_timestamp || 0);
                    const mult = (ms.position_multiplier !== undefined && ms.position_multiplier !== null)
                        ? Number(ms.position_multiplier)
                        : 1.0;

                    let tStr;
                    if (timestamp > 0) {
                        const d = new Date(timestamp * 1000);
                        const mo = d.toLocaleString('en-US', { month: 'short' });
                        const da = d.getDate();
                        const ho = d.getHours().toString().padStart(2, '0');
                        const mi = d.getMinutes().toString().padStart(2, '0');
                        tStr = `${mo} ${da} ${ho}:${mi}`;
                    } else {
                        tStr = minutesTo >= 0
                            ? `T-${Math.round(minutesTo)}m`
                            : `T+${Math.round(Math.abs(minutesTo))}m`;
                    }

                    const isPolitical = /election|vote|parliament|president|prime minister|senate|congress|government|geopolit|war|conflict|sanction|referendum|impeach|coup|minister|cabinet/i.test(ev);
                    const isHoliday = /holiday|festivo|cierre|closed/i.test(ev);

                    if (econTitle) {
                        if (isHoliday) {
                            econTitle.textContent = `⭐ Festivo / Holiday`;
                        } else {
                            econTitle.textContent = `⭐ Económico ${stars}★`;
                        }
                    }
                    if (polTitle) polTitle.textContent = `⭐ Político ${stars}★`;

                    const activeClass = 'bg-gray-900 border border-yellow-600 rounded-lg px-3 py-2 text-xs text-gray-200 min-w-[260px] text-right';
                    const offClass = 'bg-gray-900 border border-gray-700 rounded-lg px-3 py-2 text-xs text-gray-300 min-w-[260px] text-right';

                    if (active && stars >= 3 && ev) {
                        if (isPolitical) {
                            polBox.className = activeClass;
                            polText.textContent = `ACTIVE • ${tStr} • size x${mult.toFixed(2)} • ${ev}`;
                            econBox.className = offClass;
                            econText.textContent = 'OFF';
                        } else {
                            econBox.className = activeClass;
                            econText.textContent = `ACTIVE • ${tStr} • size x${mult.toFixed(2)} • ${ev}`;
                            polBox.className = offClass;
                            polText.textContent = 'OFF';
                        }
                    } else if (ev) {
                        // Show upcoming event
                        const upcomingClass = 'bg-gray-900 border border-gray-600 rounded-lg px-3 py-2 text-xs text-gray-400 min-w-[260px] text-right';
                        
                        // Calculate time difference for display
                        let timeDisplay = tStr;
                        if (minutesTo > 60) {
                            const hours = Math.floor(minutesTo / 60);
                            const mins = Math.round(minutesTo % 60);
                            timeDisplay = `T-${hours}h ${mins}m`;
                        } else if (minutesTo > 1440) { // > 24h
                             const days = Math.floor(minutesTo / 1440);
                             timeDisplay = `T-${days}d`;
                        }

                        if (isPolitical) {
                            polBox.className = upcomingClass;
                            polText.textContent = `UPCOMING • ${timeDisplay} • ${ev}`;
                            econBox.className = offClass;
                            econText.textContent = 'OFF';
                        } else {
                            econBox.className = upcomingClass;
                            econText.textContent = `UPCOMING • ${timeDisplay} • ${ev}`;
                            polBox.className = offClass;
                            polText.textContent = 'OFF';
                        }
                    } else {
                        econBox.className = offClass;
                        econText.textContent = 'OFF';
                        polBox.className = offClass;
                        polText.textContent = 'OFF';
                    }
                }
            }
            
            // Stats - Balance & Equity with color
            const balVal = data.equity.balance;
            const balEl = document.getElementById('balance');
            balEl.textContent = '$' + balVal.toFixed(2);
            balEl.className = 'stat text-xl ' + (balVal >= 1000 ? 'text-green-400' : 'text-red-400');

            const eqVal = data.equity.equity;
            const eqEl = document.getElementById('equity');
            eqEl.textContent = '$' + eqVal.toFixed(2);
            eqEl.className = 'stat text-xl ' + (eqVal >= 1000 ? 'text-green-400' : 'text-red-400');
            
            // Unrealized PnL
            const unrealized = data.equity.unrealized || 0;
            const unrealizedEl = document.getElementById('unrealized');
            unrealizedEl.textContent = (unrealized >= 0 ? '+$' : '-$') + Math.abs(unrealized).toFixed(2);
            unrealizedEl.className = 'stat text-xl ' + (unrealized > 0 ? 'text-green-400' : unrealized < 0 ? 'text-red-400' : 'text-gray-400');
            
            const pnlPct = data.stats.pnl_pct;
            const pnlEl = document.getElementById('pnl');
            pnlEl.textContent = (pnlPct >= 0 ? '+' : '') + pnlPct.toFixed(2) + '%';
            pnlEl.className = 'stat text-xl ' + (pnlPct >= 0 ? 'text-green-400' : 'text-red-400');
            
            const ddVal = data.equity.drawdown;
            const ddEl = document.getElementById('drawdown');
            ddEl.textContent = ddVal.toFixed(2) + '%';
            ddEl.className = 'stat text-xl ' + (ddVal > 0 ? 'text-red-400' : 'text-green-400');
            
            document.getElementById('totalTrades').textContent = data.stats.total_trades;

            const wrVal = data.stats.win_rate;
            const wrEl = document.getElementById('winRate');
            wrEl.textContent = wrVal.toFixed(1) + '%';
            wrEl.className = 'stat text-xl ' + (wrVal >= 50 ? 'text-green-400' : wrVal >= 40 ? 'text-yellow-400' : 'text-red-400');

            const winEl = document.getElementById('winning');
            winEl.textContent = data.stats.winning;
            winEl.className = 'stat text-xl text-green-400';

            const loseEl = document.getElementById('losing');
            loseEl.textContent = data.stats.losing;
            loseEl.className = 'stat text-xl text-red-400';

            const beEl = document.getElementById('beCount');
            beEl.textContent = data.stats.be_count || 0;
            beEl.className = 'stat text-xl text-blue-400';
            
            document.getElementById('lastUpdate').textContent = 'Updated: ' + new Date().toLocaleTimeString();

            // Trading window badge
            if (data.trading_window) {
                renderTradingWindow(data.trading_window);
            }

            // Next scan countdown
            if (data.next_scan_seconds !== undefined) {
                startCountdown(data.next_scan_seconds);
            }

            // Top crypto ticker
            updateCryptoTicker(data);

            // Trades with real PnL for metrics (CLOSE + TP1)
            const closedTrades = (data.trades || []).filter(t => t.event === 'CLOSE' || t.event === 'TP1');
            const wins = closedTrades.filter(t => t.pnl > 0);
            const losses = closedTrades.filter(t => t.pnl < 0);
            
            const avgWin = wins.length ? wins.reduce((s, t) => s + t.pnl, 0) / wins.length : 0;
            const avgLoss = losses.length ? Math.abs(losses.reduce((s, t) => s + t.pnl, 0) / losses.length) : 0;
            const profitFactor = avgLoss > 0 ? (avgWin * wins.length) / (avgLoss * losses.length) : 0;
            const bestTrade = closedTrades.length ? Math.max(...closedTrades.map(t => t.pnl || 0)) : 0;
            const worstTrade = closedTrades.length ? Math.min(...closedTrades.map(t => t.pnl || 0)) : 0;
            const expectancy = closedTrades.length ? closedTrades.reduce((s, t) => s + (t.pnl || 0), 0) / closedTrades.length : 0;

            const avgWinEl = document.getElementById('avgWin');
            avgWinEl.textContent = '+$' + avgWin.toFixed(2);
            avgWinEl.className = 'text-lg font-bold text-green-400';

            const avgLossEl = document.getElementById('avgLoss');
            avgLossEl.textContent = '-$' + avgLoss.toFixed(2);
            avgLossEl.className = 'text-lg font-bold text-red-400';

            const pfEl = document.getElementById('profitFactor');
            pfEl.textContent = profitFactor.toFixed(2);
            pfEl.className = 'text-lg font-bold ' + (profitFactor >= 1.0 ? 'text-green-400' : 'text-red-400');

            const btEl = document.getElementById('bestTrade');
            btEl.textContent = '+$' + Math.abs(bestTrade).toFixed(2);
            btEl.className = 'text-lg font-bold text-green-400';

            const wtEl = document.getElementById('worstTrade');
            wtEl.textContent = '-$' + Math.abs(worstTrade).toFixed(2);
            wtEl.className = 'text-lg font-bold text-red-400';

            const expEl = document.getElementById('expectancy');
            expEl.textContent = (expectancy >= 0 ? '+$' : '-$') + Math.abs(expectancy).toFixed(2);
            expEl.className = 'text-lg font-bold ' + (expectancy >= 0 ? 'text-green-400' : 'text-red-400');

            // Positions table
            const posTable = document.getElementById('positionsTable');
            if (data.positions.length === 0) {
                posTable.innerHTML = '<tr><td colspan="11" class="p-2 text-center text-gray-500">No open positions - AI waiting for opportunity</td></tr>';
            } else {
                posTable.innerHTML = data.positions.map(p => {
                    const pnlPct = p.entry > 0 ? ((p.current - p.entry) / p.entry * 100 * (p.direction === 'LONG' ? 1 : -1)) : 0;
                    const pnlValue = p.pnl || 0;
                    const pnlClass = pnlValue >= 0 ? 'text-green-400' : 'text-red-400';
                    const pnlPctClass = pnlPct >= 0 ? 'text-green-400' : 'text-red-400';
                    const margin = p.margin || 0;
                    const leverage = p.leverage || 3;

                    const tp1 = (p.tp1 !== null && p.tp1 !== undefined) ? p.tp1 : null;
                    const tp1Done = !!p.tp1_done;
                    const beActive = !!p.be_active;
                    const be2Active = !!p.be2_active;
                    const tsActive = !!p.ts_active;

                    const beLabel = be2Active ? 'BE2' : (beActive ? 'BE' : null);

                    const entryHtml = beLabel
                        ? `${fmtPrice(p.entry)} <span class="text-xs text-gray-400">${beLabel}</span>`
                        : `${fmtPrice(p.entry)}`;

                    const slHtml = `${fmtPrice(p.sl)}${tsActive ? ' <span class="text-xs text-gray-400">TS</span>' : ''}`;

                    return `
                    <tr class="border-t border-gray-700 hover:bg-gray-750">
                        <td class="p-0.5 font-mono font-bold">${p.symbol}</td>
                        <td class="p-0.5 ${p.direction === 'LONG' ? 'text-green-400' : 'text-red-400'} font-bold">${p.direction === 'LONG' ? '🟢 LONG' : '🔴 SHORT'}</td>
                        <td class="p-0.5 text-right text-yellow-400">$${margin.toFixed(2)}</td>
                        <td class="p-0.5 text-right text-blue-400">${leverage}x</td>
                        <td class="p-0.5 text-right">${entryHtml}</td>
                        <td class="p-0.5 text-right pos-current">${fmtPrice(p.current || p.entry)}</td>
                        <td class="p-0.5 text-right text-red-400">${slHtml}</td>
                        <td class="p-0.5 text-right text-green-400">${tp1 !== null ? (fmtPrice(tp1) + (tp1Done ? ' 🚀' : '')) : '-'}</td>
                        <td class="p-0.5 text-right font-bold ${pnlClass}">$${pnlValue.toFixed(2)}</td>
                        <td class="p-0.5 text-right font-bold ${pnlPctClass}">${pnlPct >= 0 ? '+' : ''}${pnlPct.toFixed(2)}%</td>
                        <td class="p-0.5 text-center">
                            <button onclick="closePosition('${p.symbol}')" class="bg-red-600 hover:bg-red-700 text-white px-2 py-1 rounded text-xs transition">Close</button>
                        </td>
                    </tr>
                `}).join('');
            }

            // Count actions for pie chart
            actionCounts = { HOLD: 0, LONG: 0, SHORT: 0, CLOSE: 0 };
            (data.decisions || []).forEach(d => {
                const rec = d.recommendation || 'HOLD';
                if (actionCounts.hasOwnProperty(rec)) {
                    actionCounts[rec]++;
                }
            });

            // PnL and trades by symbol (CLOSE + TP1 events)
            symbolPnL = {};
            symbolTrades = {};
            closedTrades.forEach(t => {
                if (!symbolPnL[t.symbol]) {
                    symbolPnL[t.symbol] = 0;
                    symbolTrades[t.symbol] = 0;
                }
                symbolPnL[t.symbol] += t.pnl || 0;
                symbolTrades[t.symbol]++;
            });

            // Decisions table
            const decTable = document.getElementById('decisionsTable');
            if (data.decisions && data.decisions.length > 0) {
                decTable.innerHTML = data.decisions.slice(0, 30).map(d => {
                    const rec = d.recommendation || 'HOLD';
                    const actionIcon = rec === 'LONG' ? '🟢' : rec === 'SHORT' ? '🔴' : rec === 'CLOSE' ? '⚪' : '⏸️';
                    const actionClass = rec === 'LONG' ? 'text-green-400' : rec === 'SHORT' ? 'text-red-400' : 'text-gray-400';
                    const conf = d.confidence !== undefined ? (d.confidence * 100).toFixed(0) + '%' : '—';
                    const probs = d.agent_probs || [];
                    const probStr = probs.length === 3 ? `H:${(probs[0]*100).toFixed(0)} L:${(probs[1]*100).toFixed(0)} S:${(probs[2]*100).toFixed(0)}` : '';
                    return `
                    <tr class="border-t border-gray-700 hover:bg-gray-750">
                        <td class="p-2 text-xs text-gray-400">${new Date(d.ts).toLocaleTimeString()}</td>
                        <td class="p-2 font-mono">${d.symbol}</td>
                        <td class="p-2 text-center ${actionClass} font-bold">${actionIcon} ${rec}</td>
                        <td class="p-2 text-right">${fmtPrice(d.price)}</td>
                        <td class="p-2 text-center text-blue-400 text-xs">${conf}</td>
                        <td class="p-2 text-xs text-gray-300" title="${probStr}">${probStr || '—'}</td>
                    </tr>
                `}).join('');
            } else {
                decTable.innerHTML = '<tr><td colspan="6" class="p-4 text-center text-gray-500">Waiting for AI decisions...</td></tr>';
            }

            // Trades table — show all events except OPEN (includes BE, TP1, CLOSE)
            allTrades = (data.trades || []).filter(t => t.event !== 'OPEN');
            renderTradesTable();

            // Update all charts
            updateEquityChart(data.equity_history);
            updateDrawdownChart(data.equity_history);
            updateWinLossChart(data.stats.winning, data.stats.losing, data.stats.be_count || 0);
            updateActionsChart();
            updatePnLBySymbolChart();
            updateTradesBySymbolChart();
        }

        function updateEquityChart(history) {
            const ctx = document.getElementById('equityChart').getContext('2d');
            const labels = history.map(h => new Date(h.ts).toLocaleTimeString());
            const values = history.map(h => h.equity);
            
            if (charts.equity) {
                charts.equity.data.labels = labels;
                charts.equity.data.datasets[0].data = values;
                charts.equity.update('none');
            } else {
                charts.equity = new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: 'Equity',
                            data: values,
                            borderColor: '#10B981',
                            borderWidth: 1,
                            backgroundColor: 'rgba(16, 185, 129, 0.05)',
                            fill: true,
                            tension: 0.3,
                            pointRadius: 0,
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } },
                        scales: {
                            x: { display: false },
                            y: { grid: { color: '#374151' }, ticks: { color: '#9CA3AF' } }
                        }
                    }
                });
            }
        }

        function updateDrawdownChart(history) {
            const ctx = document.getElementById('drawdownChart').getContext('2d');
            const labels = history.map(h => new Date(h.ts).toLocaleTimeString());
            const values = history.map(h => Math.abs(h.dd || 0));
            
            if (charts.drawdown) {
                charts.drawdown.data.labels = labels;
                charts.drawdown.data.datasets[0].data = values;
                charts.drawdown.update('none');
            } else {
                charts.drawdown = new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: 'Drawdown',
                            data: values,
                            borderColor: '#EF4444',
                            borderWidth: 1,
                            backgroundColor: 'rgba(239, 68, 68, 0.1)',
                            fill: true,
                            tension: 0.3,
                            pointRadius: 0,
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } },
                        scales: {
                            x: { display: false },
