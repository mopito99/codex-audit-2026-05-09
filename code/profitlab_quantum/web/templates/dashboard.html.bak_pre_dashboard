                    }
                });
            }
        }

        // ============ MARKET CLOCKS ============
        const markets = {
            tokyo: { tz: 'Asia/Tokyo', open: 9, close: 15, name: 'Tokyo', displayHours: '09:00 - 15:00 JST' },
            hk: { tz: 'Asia/Hong_Kong', open: 9.5, close: 16, name: 'Hong Kong', displayHours: '09:30 - 16:00 HKT' },
            london: { tz: 'Europe/London', open: 8, close: 16.5, name: 'London', displayHours: '08:00 - 16:30 UTC' },
            ny: { tz: 'America/New_York', open: 9.5, close: 16, name: 'NYSE', displayHours: '09:30 - 16:00 ET' },
            cme: { tz: 'America/Chicago', open: 17, close: 16, isCME: true, name: 'CME', displayHours: '17:00 - 16:00 CT' }
        };

        // Holiday Logic (Auto-detect)
        (function() {
