        setInterval(updateGoldenHourBadge, 30000); // Check every 30 seconds

        function updateCryptoTicker(data) {
            const el = document.getElementById('cryptoTicker');
            if (!el) return;

            const items = [];

            // Prefer backend ticker (has % change)
            if (Array.isArray(data.ticker) && data.ticker.length) {
                data.ticker.slice(0, 20).forEach(t => {
                    const sym = t.symbol;
                    const price = Number(t.price);
                    const chg = Number(t.change_pct);
                    if (!sym || !Number.isFinite(price) || !Number.isFinite(chg)) return;
                    const up = chg >= 0;
                    const cls = up ? 'text-green-400' : 'text-red-400';
                    const arrow = up ? '▲' : '▼';
                    const pStr = price.toFixed(price >= 100 ? 0 : 4);
                    const pct = Math.abs(chg).toFixed(2);
                    items.push(
                        `<span class=\"inline-flex items-center gap-2 px-2\">` +
                            `<span class=\"text-pink-100 font-semibold\">${sym}</span>` +
                            `<span class=\"${cls} font-bold\">${arrow}</span>` +
                            `<span class=\"text-pink-100 tabular-nums\">${pStr}</span>` +
                            `<span class=\"${cls} tabular-nums\">${up ? '+' : '-'}${pct}%</span>` +
                        `</span>`
                    );
                });
            }

            // Fallback: use live prices from open positions / decisions (no % change)
            if (!items.length) {
                const seen = new Set();
                const add = (symbol, price) => {
                    if (!symbol || seen.has(symbol)) return;
                    seen.add(symbol);
                    if (price !== undefined && price !== null && !Number.isNaN(Number(price))) {
                        const p = Number(price);
                        items.push(`${symbol} ${p.toFixed(p >= 100 ? 0 : 4)}`);
                    } else {
                        items.push(`${symbol}`);
                    }
                };
                (data.positions || []).forEach(p => add(p.symbol, p.current));
                (data.decisions || []).forEach(d => add(d.symbol, d.price));
            }

            if (items.length === 0) {
                el.textContent = 'BTC-USDT • ETH-USDT • SOL-USDT • BNB-USDT • XRP-USDT • LTC-USDT';
                return;
            }

            const line = items.join('   •   ');
            // Duplicate for smoother loop
            el.innerHTML = `${line}   •   ${line}`;
        }

