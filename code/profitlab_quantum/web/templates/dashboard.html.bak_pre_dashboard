        setInterval(updateWeekendCountdown, 1000);

        // ============ GOLDEN HOUR BADGE ============
        function updateGoldenHourBadge() {
            const now = new Date();
            const utcHour = now.getUTCHours();
            const utcMin = now.getUTCMinutes();
            const currentMinutes = utcHour * 60 + utcMin; // Total minutes since midnight UTC
            const day = now.getUTCDay(); // 0=Sun, 6=Sat
            
            const badge = document.getElementById('hourBadge');
            const badgeIcon = document.getElementById('hourBadgeIcon');
            const badgeText = document.getElementById('hourBadgeText');
            
            if (!badge || !badgeIcon || !badgeText) return;

            // Weekend Check
            if (day === 0 || day === 6) {
                 badge.style.background = 'linear-gradient(135deg, #374151, #1f2937)';
                 badge.style.boxShadow = 'none';
                 badge.style.animation = 'none';
                 badgeIcon.textContent = '🏖️';
                 badgeText.textContent = 'FIN DE SEMANA';
                 return;
            }
            
            // Define time windows (in minutes from midnight UTC)
            const windows = [
                { name: 'silver1', start: 7*60, end: 9*60, icon: '🥈', label: 'HORA PLATA', gradient: 'linear-gradient(135deg, #9CA3AF, #6B7280)' },
                { name: 'golden', start: 14*60+30, end: 17*60, icon: '🪙', label: 'HORA DORADA', gradient: 'linear-gradient(135deg, #F59E0B, #D97706)' },
                { name: 'silver2', start: 21*60, end: 23*60, icon: '🥈', label: 'HORA PLATA', gradient: 'linear-gradient(135deg, #9CA3AF, #6B7280)' },
            ];
            
            // Check if we're in any active window
            let activeWindow = null;
            for (const w of windows) {
                if (currentMinutes >= w.start && currentMinutes <= w.end) {
                    activeWindow = w;
                    break;
                }
            }
            
            if (activeWindow) {
                // Show active badge
                badge.style.background = activeWindow.gradient;
                badge.style.boxShadow = activeWindow.name === 'golden' ? '0 0 15px rgba(245, 158, 11, 0.5)' : 'none';
                badge.style.animation = 'pulse 2s infinite';
                badgeIcon.textContent = activeWindow.icon;
                badgeText.textContent = `${activeWindow.label} ✨`;
                return;
            }
            
            // Find next window
            let nextWindow = null;
            let minWait = Infinity;
            
            for (const w of windows) {
                let waitMinutes = w.start - currentMinutes;
                if (waitMinutes < 0) {
                    waitMinutes += 24 * 60; // Next day
                }
                if (waitMinutes < minWait) {
                    minWait = waitMinutes;
                    nextWindow = w;
                }
            }
            
            if (nextWindow) {
                // Format countdown
                const hours = Math.floor(minWait / 60);
                const mins = minWait % 60;
                let countdown = hours > 0 ? `${hours}h ${mins}m` : `${mins}m`;
                
                // Show the badge for the next window with countdown
                badge.style.background = nextWindow.gradient;
                badge.style.boxShadow = 'none';
                badge.style.animation = 'none';
                badgeIcon.textContent = nextWindow.icon;
                badgeText.textContent = `${nextWindow.label} en ${countdown}`;
            }
        }
        
