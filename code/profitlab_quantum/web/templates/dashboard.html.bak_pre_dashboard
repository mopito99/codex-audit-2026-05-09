            const id = intervalCount;
            const container = document.getElementById('intervalsContainer');
            const div = document.createElement('div');
            div.className = "flex items-center gap-2 interval-row";
            div.id = `interval-${id}`;
            div.innerHTML = `
                <input type="time" class="bg-gray-800 border border-gray-600 rounded px-2 py-1 text-sm text-gray-200 focus:border-blue-500 outline-none" name="start" value="${start}" required>
                <span class="text-gray-400 text-xs">to</span>
                <input type="time" class="bg-gray-800 border border-gray-600 rounded px-2 py-1 text-sm text-gray-200 focus:border-blue-500 outline-none" name="end" value="${end}" required>
                <button type="button" onclick="removeIntervalRow(${id})" class="text-red-400 hover:text-red-300 px-2">✕</button>
            `;
            container.appendChild(div);
        }

        function removeIntervalRow(id) {
            const el = document.getElementById(`interval-${id}`);
            if (el) el.remove();
        }

        function clearIntervals() {
            document.getElementById('intervalsContainer').innerHTML = '';
        }

        function applyPreset(name) {
            const tzInput = document.getElementById('twTz');
            const weekendSelect = document.getElementById('twWeekend');
            const enabledCheck = document.getElementById('twEnabled');
            
            // All presets use UTC for simplicity in this implementation
            tzInput.value = "UTC";
            // Auto-enable when selecting a preset
            enabledCheck.checked = true;
            
            clearIntervals();

            if (name === 'london_ny') {
                // 13:00 - 16:00 UTC
                addIntervalRow("13:00", "16:00");
                weekendSelect.value = "block";
            } else if (name === 'us_stocks') {
                // 13:30 - 20:00 UTC
                addIntervalRow("13:30", "20:00");
                weekendSelect.value = "block";
            } else if (name === 'full_day') {
                // 07:00 - 21:00 UTC
                addIntervalRow("07:00", "21:00");
                weekendSelect.value = "allow";
            } else if (name === 'asian') {
                // 00:00 - 08:00 UTC
                addIntervalRow("00:00", "08:00");
                weekendSelect.value = "allow";
            }
        }

        async function loadTradingWindow() {
            try {
                const res = await fetch('/api/trading-window');
                const data = await res.json();
                
                currentTradingWindowConfig = data; // Store global config for UI highlighting

                document.getElementById('twEnabled').checked = data.enabled;
                document.getElementById('twTz').value = data.tz || "UTC";
                document.getElementById('twWeekend').value = data.weekend_mode || "allow";
                
                const badge = document.getElementById('scheduleBadge');
                const statusDiv = document.getElementById('scheduleStatus');
                
                if (data.enabled) {
                    badge.textContent = data.is_open ? "OPEN" : "CLOSED";
                    badge.className = data.is_open 
                        ? "px-3 py-1 rounded-full text-xs font-semibold bg-green-900/30 border border-green-600 text-green-400"
                        : "px-3 py-1 rounded-full text-xs font-semibold bg-red-900/30 border border-red-600 text-red-400";
                    statusDiv.textContent = `${data.reason || ''}. Local: ${data.local_time} (${data.tz})`;
                } else {
                    badge.textContent = "DISABLED";
                    badge.className = "px-3 py-1 rounded-full text-xs font-semibold bg-gray-700/30 border border-gray-600 text-gray-300";
                    statusDiv.textContent = `Sin horario activo (no bloquea entradas). Local: ${data.local_time} (${data.tz}).`;
                }

                clearIntervals();
                if (data.intervals && data.intervals.length > 0) {
                    data.intervals.forEach(iv => addIntervalRow(iv.start, iv.end));
                } else {
                    if (data.enabled && (!data.intervals || data.intervals.length === 0)) {
                        addIntervalRow();
                    }
                }
                
                // Force update indicators immediately
                updateSessionIndicators();

            } catch (e) {
                console.error(e);
            }
        }

        async function submitTradingWindow(e) {
            e.preventDefault();
            const statusEl = document.getElementById('scheduleSaveStatus');
            statusEl.textContent = "Saving...";
            
            const enabled = document.getElementById('twEnabled').checked;
            const tz = document.getElementById('twTz').value;
            const weekend_mode = document.getElementById('twWeekend').value;
            
            // Gather intervals
            const rows = document.querySelectorAll('.interval-row');
            const intervals = [];
            rows.forEach(row => {
                const start = row.querySelector('input[name="start"]').value;
                const end = row.querySelector('input[name="end"]').value;
                if (start && end) {
                    intervals.push({ start, end });
                }
            });

            try {
                const res = await fetch('/api/trading-window', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({
                        enabled: enabled,
                        tz: tz,
                        weekend_mode: weekend_mode,
                        intervals: intervals
                    })
                });
                const data = await res.json();
                if (data.status === 'ok') {
                    statusEl.textContent = "Saved!";
                    statusEl.className = "text-xs text-green-400";
                    loadTradingWindow();
                } else {
                    statusEl.textContent = "Error: " + data.detail;
                    statusEl.className = "text-xs text-red-400";
                }
            } catch (e) {
                statusEl.textContent = "Error saving";
                statusEl.className = "text-xs text-red-400";
            }
            
            setTimeout(() => { statusEl.textContent = ""; }, 3000);
        }

        </script>
    <div id="debugStatus" class="fixed bottom-1 right-1 text-[10px] text-gray-600 font-mono pointer-events-none opacity-50"></div>
</body>
</html>