class QuantumEngine:
    def __init__(self, initial_capital=10000.0, *, symbol: str | None = None):
        self.capital = initial_capital
        self.portfolio_value = initial_capital

        self.symbol = str(symbol) if symbol is not None else None
        
        # Shared calendar path
        self.market_context = get_market_context("/root/srv/profitlab_ai_link/config/event_calendar_usd_high_plus_holidays.csv")
        
        self.feature_calculator = SMCFeatureCalculator()
        self.risk_manager = RiskManager()
        self.risk_manager.set_initial_capital(initial_capital)
        
        # Input dim: OHLCV (5) + SMC Features (approx 14)
        # We need to dynamically determine input_dim or fix it.
        # Let's check the number of features generated by SMCFeatureCalculator
        # For now, we'll use a larger number and pad/truncate or just re-initialize if needed.
        # But better: The agent expects a fixed input size.
        # Let's count the columns in smc_features.py:
        # open, high, low, close, volume (5)
        # fvg_bull_size, fvg_bear_size, is_fvg_bull, is_fvg_bear (4)
        # is_ob_bull, is_ob_bear, ob_top, ob_bottom, ob_bull_top, ob_bull_bottom, ob_bear_top, ob_bear_bottom (8)
        # is_sweep_high, is_sweep_low (2)
        # We build an explicit, stable state vector:
        # 5 OHLCV + 4 FVG + 2 sweeps + 8 OB proximity/freshness + 2 HTF context = 21
        self.state_columns = [
            'open', 'high', 'low', 'close', 'volume',
            'fvg_bull_size', 'fvg_bear_size', 'is_fvg_bull', 'is_fvg_bear',
            'is_sweep_high', 'is_sweep_low',
            'bull_ob_distance', 'bear_ob_distance',
            'bull_ob_age', 'bear_ob_age',
            'bull_ob_tests', 'bear_ob_tests',
            'bull_ob_mitigated', 'bear_ob_mitigated',
            'htf_bias', 'htf_trend',
        ]
        self.input_dim = len(self.state_columns)

        def _safe_symbol_for_path(sym: str) -> str:
            s = (sym or "").strip().upper()
            out = []
            for ch in s:
                if ch.isalnum() or ch in ("-", "_", "."):
                    out.append(ch)
                else:
                    out.append("_")
            return "".join(out) or "UNKNOWN"

        def _ppo_weights_path() -> Path:
            if bool(PPO_PER_SYMBOL) and self.symbol:
                sym = _safe_symbol_for_path(self.symbol)
                return Path(str(PPO_WEIGHTS_DIR)) / sym / "ppo.pt"
            return Path(str(PPO_WEIGHTS_PATH))

        if AGENT_TYPE == "decision_transformer":
            # If dt_meta exists, use it to reconstruct the exact architecture.
            dt_cfg = DTConfig(state_dim=self.input_dim, act_dim=3, context_len=int(DT_CONTEXT_LEN))
            meta_path = Path(str(DT_META_PATH))
            if meta_path.exists():
                try:
                    meta = json.loads(meta_path.read_text())
                    dt_cfg = DTConfig(
                        state_dim=self.input_dim,
                        act_dim=3,
                        context_len=int(meta.get("context_len", DT_CONTEXT_LEN)),
                        d_model=int(meta.get("d_model", 128)),
                        nhead=int(meta.get("nhead", 4)),
                        nlayer=int(meta.get("nlayer", 3)),
                    )
                except Exception:
                    pass

            dt_model = DecisionTransformer(dt_cfg)
            weights_path = Path(str(DT_WEIGHTS_PATH))
            if weights_path.exists():
                try:
                    dt_model.load_state_dict(torch.load(str(weights_path), map_location="cpu"))
                except Exception:
                    pass

            self.agent = DecisionTransformerAgent(dt_model, target_rtg=float(DT_TARGET_RTG))
        else:
            weights_path = _ppo_weights_path()
            # In chunked mode (2/day), autosave every update by default.
            autosave_every = 1 if str(PPO_LEARNING_MODE).strip().lower() == "chunked" else None
            self.agent = QuantumAgent(
                input_dim=self.input_dim,
                action_dim=3,
                autosave_path=str(weights_path),
                autosave_every_updates=autosave_every,
            )  # Buy, Sell, Hold
            if weights_path.exists():
                try:
                    self.agent.load(str(weights_path))
                except Exception:
                    pass
            else:
                # If per-symbol weights are missing, optionally bootstrap from legacy global weights.
                # This avoids starting from scratch while keeping learning isolated per symbol.
                try:
                    legacy = Path(str(PPO_WEIGHTS_PATH))
                    if legacy.exists():
                        self.agent.load(str(legacy))
                except Exception:
                    pass
        
        # Learning State
        self.prev_state = None
        self.prev_action = None
        self.prev_price = None
        self.prev_log_prob = None
        self.prev_value = None
        self._returns_window = []
        self._returns_window_maxlen = 120

        # Chunked learning schedule (per engine/per symbol)
        self._last_train_ts_ms: int | None = None

    def maybe_train(self, *, now_ts_ms: int) -> bool:
        """Chunked PPO training: rolling buffer (default 72h) updated every 12h."""
        if not bool(getattr(self.agent, "is_on_policy", True)):
            return False

        if str(PPO_LEARNING_MODE).strip().lower() != "chunked":
            return False

        try:
            window_h = float(PPO_CHUNK_WINDOW_HOURS)
            every_h = float(PPO_CHUNK_UPDATE_EVERY_HOURS)
        except Exception:
            return False

        if window_h <= 0 or every_h <= 0:
            return False

        window_ms = int(window_h * 3600.0 * 1000.0)
        every_ms = int(every_h * 3600.0 * 1000.0)
        min_ts_ms = int(now_ts_ms) - int(window_ms)

        if hasattr(self.agent, "prune_memory"):
            try:
                self.agent.prune_memory(min_ts_ms=int(min_ts_ms))
            except Exception:
                pass

        if self._last_train_ts_ms is None:
            self._last_train_ts_ms = int(now_ts_ms)
            return False

        if int(now_ts_ms) - int(self._last_train_ts_ms) < int(every_ms):
            return False

        min_samples = max(32, int(PPO_CHUNK_MIN_SAMPLES))
        if len(getattr(self.agent, "memory", [])) < int(min_samples):
            return False

        max_samples = int(PPO_CHUNK_MAX_SAMPLES)
        if max_samples > 0 and len(self.agent.memory) > max_samples:
            self.agent.memory = self.agent.memory[-max_samples:]

        try:
            before = int(getattr(self.agent, "_update_count", 0) or 0)
            self.agent.update(clear_memory=False)
            after = int(getattr(self.agent, "_update_count", 0) or 0)
            if after > before:
                self._last_train_ts_ms = int(now_ts_ms)
                return True
            return False
        except Exception:
            return False
        
    def step(
        self,
        market_data: pd.DataFrame,
        htf_data: pd.DataFrame | None = None,
        symbol: str | None = None,
        microstructure: dict | None = None,
    ):
        """
        Execute one step of the trading loop.
        """
        # Timestamp for scheduling/training (prefer kline time)
        now_ts_ms = None
        try:
            if "time" in market_data.columns and len(market_data) > 0:
                now_ts_ms = int(market_data["time"].iloc[-1])
        except Exception:
            now_ts_ms = None
        if now_ts_ms is None:
            now_ts_ms = int(pd.Timestamp.utcnow().value // 1_000_000)

        # 1. Calculate Features (5m execution layer)
        features = self.feature_calculator.calculate_all(market_data)
        current_state = features.iloc[-1]

        # Higher timeframe context (1h bias layer)
        htf_bias = 0.0
        htf_trend = 0.0
        if htf_data is not None and not htf_data.empty:
            try:
                htf_features = self.feature_calculator.calculate_all(htf_data)
                htf_state = htf_features.iloc[-1]

                bull = int(htf_state.get('is_ob_bull', 0)) + int(htf_state.get('is_fvg_bull', 0))
                bear = int(htf_state.get('is_ob_bear', 0)) + int(htf_state.get('is_fvg_bear', 0))
                htf_bias = float(np.clip(bull - bear, -2, 2))

                # Simple trend proxy on HTF
                try:
                    htf_close = htf_data['close']
                    if len(htf_close) >= 13:
                        ref = float(htf_close.iloc[-13])
                        last = float(htf_close.iloc[-1])
                        if ref != 0:
                            htf_trend = float(np.clip((last - ref) / ref, -0.05, 0.05))
                except Exception:
                    pass
            except Exception:
                pass
        
        # Prepare state vector for Agent (explicit feature set)
        row = features.iloc[-1].copy()
        row['htf_bias'] = float(htf_bias)
        row['htf_trend'] = float(htf_trend)
        state_values = []
        for col in self.state_columns:
            try:
                v = row.get(col, 0.0)
                if v is None or (isinstance(v, float) and not np.isfinite(v)):
                    v = 0.0
                state_values.append(float(v))
            except Exception:
                state_values.append(0.0)
        state_vector = np.array(state_values, dtype=np.float32)

        # --- Input normalization to avoid policy saturation ---
        # Raw prices/volumes are large; without normalization the softmax can become [0,1,0].
        finite = np.isfinite(state_vector)
        if finite.any():
            scale = float(np.median(np.abs(state_vector[finite])))
        else:
            scale = 1.0
        if not np.isfinite(scale) or scale <= 1e-8:
            scale = 1.0
        state_vector = np.clip(state_vector / scale, -10.0, 10.0)
        
        # 2. Get Agent Action (PPO on-policy)
        action, log_prob, value, policy, seq_state = self.agent.get_action(state_vector)
        probs = policy.detach().cpu().numpy().tolist()  # [prob_hold, prob_long, prob_short]
        
        # --- Continuous Learning Step (PPO) ---
        current_price = float(current_state.get('close', 0))
        
        if bool(getattr(self.agent, "is_on_policy", True)) and self.prev_state is not None and self.prev_action is not None:
            # Reward: differential Sortino-style (penalize downside volatility only)
            pct_change = (current_price - self.prev_price) / self.prev_price if self.prev_price else 0.0

            if self.prev_action == 1:  # Long
                realized_r = float(pct_change)
            elif self.prev_action == 2:  # Short
                realized_r = float(-pct_change)
            else:  # Hold
                realized_r = 0.0

            self._returns_window.append(realized_r)
            if len(self._returns_window) > self._returns_window_maxlen:
                self._returns_window = self._returns_window[-self._returns_window_maxlen :]

            downside = [r for r in self._returns_window if r < 0.0]
            downside_dev = float(np.sqrt(np.mean(np.square(downside)))) if len(downside) > 0 else 0.0
            reward = realized_r / (downside_dev + 1e-6)

            # Mild penalty for idling (keeps policy from collapsing into HOLD)
            if self.prev_action == 0:
                reward -= 0.001

            # Store transition (on-policy)
            if hasattr(self.agent, "remember"):
                try:
                    self.agent.remember(
                        self.prev_state,
                        self.prev_action,
                        float(reward),
                        False,
                        self.prev_log_prob,
                        self.prev_value,
                        int(now_ts_ms),
                    )
                except TypeError:
                    # Backwards compatibility for older remember signature
                    self.agent.remember(
                        self.prev_state,
                        self.prev_action,
                        float(reward),
                        False,
                        self.prev_log_prob,
                        self.prev_value,
                    )

            # Learning mode:
            # - online: update immediately when buffer is ready
            # - chunked: scheduled updates handled by maybe_train()
            if str(PPO_LEARNING_MODE).strip().lower() == "online":
                if hasattr(self.agent, "update"):
                    self.agent.update(clear_memory=True)
            
        # 2.1 Institutional SMC gating (sniper entries only)
        # Allow trades only when confluence exists:
        # - Liquidity sweep in direction
        # - Order Block context
        # - FVG context
        # - HTF bias alignment

        def _safe_float(v, default=None):
            try:
                x = float(v)
                if not np.isfinite(x):
                    return default
                return x
            except Exception:
                return default

        def _json_float(v):
            x = _safe_float(v, default=None)
            return None if x is None else float(x)

        sweep_low = int(current_state.get('is_sweep_low', 0) or 0)
        sweep_high = int(current_state.get('is_sweep_high', 0) or 0)

        px = float(current_price) if current_price else 0.0

        # Use quantified proximity/freshness features (active zones, not just detection candle).
        bull_ob_dist = _safe_float(current_state.get('bull_ob_distance', None), default=None)
        bear_ob_dist = _safe_float(current_state.get('bear_ob_distance', None), default=None)
        bull_ob_age = _safe_float(current_state.get('bull_ob_age', 999.0), default=999.0)
        bear_ob_age = _safe_float(current_state.get('bear_ob_age', 999.0), default=999.0)
        bull_ob_mit = int(current_state.get('bull_ob_mitigated', 0) or 0)
        bear_ob_mit = int(current_state.get('bear_ob_mitigated', 0) or 0)

        fvg_bull_dist = _safe_float(current_state.get('fvg_bull_distance', None), default=None)
        fvg_bear_dist = _safe_float(current_state.get('fvg_bear_distance', None), default=None)
        fvg_bull_age = _safe_float(current_state.get('fvg_bull_age', 999.0), default=999.0)
        fvg_bear_age = _safe_float(current_state.get('fvg_bear_age', 999.0), default=999.0)
        fvg_bull_mit = int(current_state.get('fvg_bull_mitigated', 0) or 0)
        fvg_bear_mit = int(current_state.get('fvg_bear_mitigated', 0) or 0)

        # Institutional thresholds (percent-of-price), tuned to be strict but workable.
        # These encode "proximity" and "freshness" explicitly.
        ob_prox = (abs(px) * 0.0015) if px else 0.0  # 0.15%
        fvg_prox = (abs(px) * 0.0010) if px else 0.0  # 0.10%
        max_ob_age = 80.0
        max_fvg_age = 30.0

        near_bull_ob = int((bull_ob_dist is not None) and (bull_ob_dist <= ob_prox) and (bull_ob_age <= max_ob_age) and (bull_ob_mit == 0))
        near_bear_ob = int((bear_ob_dist is not None) and (bear_ob_dist <= ob_prox) and (bear_ob_age <= max_ob_age) and (bear_ob_mit == 0))

        fvg_bull_ok = int((fvg_bull_dist is not None) and (fvg_bull_dist <= fvg_prox) and (fvg_bull_age <= max_fvg_age) and (fvg_bull_mit == 0))
        fvg_bear_ok = int((fvg_bear_dist is not None) and (fvg_bear_dist <= fvg_prox) and (fvg_bear_age <= max_fvg_age) and (fvg_bear_mit == 0))

        htf_long_ok = int(htf_bias >= 1.0)
        htf_short_ok = int(htf_bias <= -1.0)

        long_score = int(sweep_low == 1) + int(near_bull_ob == 1) + int(fvg_bull_ok == 1) + int(htf_long_ok == 1)
        short_score = int(sweep_high == 1) + int(near_bear_ob == 1) + int(fvg_bear_ok == 1) + int(htf_short_ok == 1)

        allow_long = long_score >= 3
        allow_short = short_score >= 3

        if not allow_long and not allow_short:
            action = 0
        elif allow_long and not allow_short:
            action = 1
        elif allow_short and not allow_long:
            action = 2
        else:
            # both allowed: keep agent action but disallow HOLD
            if action == 0:
                action = 1 if long_score >= short_score else 2

        # Ensure log_prob matches the final (possibly gated) action
        try:
            dist = torch.distributions.Categorical(policy)
            action_t = torch.tensor([action], device=self.agent.device)
            log_prob = dist.log_prob(action_t).squeeze(0)
        except Exception:
            pass

        # Update state for next step (store gated action)
        self.prev_state = seq_state
        self.prev_action = action
        self.prev_price = current_price
        self.prev_log_prob = log_prob
        self.prev_value = value
        # -------------------------------

        # Chunked PPO update (2/day) using rolling 72h window.
        # Kept separate from signal generation to avoid step-time instability.
        if str(PPO_LEARNING_MODE).strip().lower() == "chunked":
            self.maybe_train(now_ts_ms=int(now_ts_ms))
        
        # 3. Risk Management
        # Get Market Context (Event Risk, Holidays, etc.)
        try:
            m_status = self.market_context.get_status(pd.Timestamp.now(tz='UTC'))
            event_mult = float(m_status.position_size_multiplier)
            is_paused = "pause" in str(m_status.trading_mode).lower()
        except Exception:
            event_mult = 1.0
            is_paused = False

        # Calculate volatility (simplified rolling std of close)
        # Annualization factor for 5m data: sqrt(288 periods/day * 365 days) = sqrt(105120) approx 324.2
        ann_factor = 324.2
        current_vol = market_data['close'].pct_change().rolling(window=20).std().iloc[-1] * ann_factor
        if np.isnan(current_vol):
            current_vol = 0.60 # Default fallback (crypto typical)
            
        # 3. Risk Management (Report-aligned intent):
        # - CPPI defines how much *margin* we are allowed to put at risk (capital brake).
        # - Volatility targeting defines leverage (aggression) up to 20x.
        # - Notional = margin * leverage.
        # Hard brake: if portfolio touches floor, do not trade.
        if self.risk_manager.floor_value is not None and self.portfolio_value <= self.risk_manager.floor_value:
            action = 0
        
        # Event Risk Hard Brake
        if is_paused:
            action = 0

        max_leverage = 20.0

        # CPPI margin cap (treat cushion*m as max margin allocation)
        cushion = float(self.portfolio_value - float(self.risk_manager.floor_value or 0.0))
        margin_cap_usd = float(self.risk_manager.cppi_multiplier) * max(0.0, cushion)
        margin_cap_usd = float(np.clip(margin_cap_usd, 0.0, float(self.portfolio_value)))

        # Volatility targeting (report-style) proposes a desired notional.
        desired_notional_raw = float(self.risk_manager.calculate_vol_targeting_position(current_vol, self.portfolio_value))

        # Scale aggressiveness by setup quality (sniper): stronger confluence => closer to desired_notional.
        setup_quality = float(max(long_score, short_score)) / 4.0
        setup_quality = float(np.clip(setup_quality, 0.0, 1.0))

        # --- INSTITUTIONAL CONFIDENCE FILTER ---
        # If strict CPPI forces a micro-position (e.g. < $10 margin), we check if the setup is high-quality.
        # If Confidence >= 0.6 (3/4 factors), we allow a "Minimum Viable Ticket" ($10 margin).
        min_margin_usd = 10.0
        if margin_cap_usd < min_margin_usd and self.portfolio_value > (min_margin_usd * 2.0):
            if setup_quality >= 0.60:
                print(f"Risk Override: Upgrading margin to ${min_margin_usd} due to High Confidence ({setup_quality:.2f})")
                margin_cap_usd = min_margin_usd
            else:
                # Low confidence + Low capital = No Trade (or strict micro-trade)
                # We enforce strict floor if confidence is low
                if margin_cap_usd < 1.0:
                    margin_cap_usd = 0.0
        
        # Apply Event Risk Multiplier
        desired_notional = float(desired_notional_raw) * float(setup_quality) * event_mult

        # Expose a "max safe" notional independent of the gated action.
        # This is what the sizing engine would allow if a trade were taken.
        # (Strategy page prefers risk.safe_size; falls back to notional_usd/margin_usd otherwise.)
        if margin_cap_usd <= 0.0:
            safe_size = 0.0
        else:
            safe_size = float(min(float(desired_notional_raw), float(margin_cap_usd) * float(max_leverage)))

        if action == 0 or margin_cap_usd <= 0.0:
            notional_usd = 0.0
            leverage = 1.0
            margin_usd = 0.0
        else:
            margin_usd = float(margin_cap_usd)

            # Convert desired notional into leverage, bounded by [1, 20].
            if not np.isfinite(desired_notional) or desired_notional <= 0.0:
                leverage = 1.0
            else:
                leverage = float(np.clip(desired_notional / margin_usd, 1.0, max_leverage))

            notional_usd = float(margin_usd) * float(leverage)

        print(
            f"Action: {action}, Margin: {margin_usd:.2f}, Lev: {leverage:.2f}x, Notional: {notional_usd:.2f}, Portfolio: {self.portfolio_value:.2f}"
        )

        # 3.1 SL/TP suggestion (SMC-derived, single SL + single TP, no partials)
        # Institutional-style: SL beyond the active Order Block (or recent swing), TP at opposing liquidity pool.
        sl_price = None
        tp_price = None
        rr = 2.0

        # Recent liquidity pools (swing highs/lows) from recent candles (exclude current candle)
        try:
            lookback_liq = 20
            recent_high = float(market_data['high'].iloc[-(lookback_liq + 1):-1].max())
            recent_low = float(market_data['low'].iloc[-(lookback_liq + 1):-1].min())
        except Exception:
            recent_high = None
            recent_low = None

        # Use active OB levels (forward-filled) for structural SL placement.
        ob_bull_top = _safe_float(current_state.get('active_ob_bull_top', None), default=None)
        ob_bull_bottom = _safe_float(current_state.get('active_ob_bull_bottom', None), default=None)
        ob_bear_top = _safe_float(current_state.get('active_ob_bear_top', None), default=None)
        ob_bear_bottom = _safe_float(current_state.get('active_ob_bear_bottom', None), default=None)

        # Small structural buffer (in price units): 0.10% of price or 25% of OB range, whichever is larger.
        px = float(current_price) if current_price else 0.0
        pct_buf = abs(px) * 0.001

        if action == 1:  # LONG
            if ob_bull_bottom is not None and ob_bull_top is not None and ob_bull_bottom > 0:
                ob_range = max(0.0, float(ob_bull_top - ob_bull_bottom))
                buf = max(pct_buf, 0.25 * ob_range)
                sl_price = float(ob_bull_bottom - buf)
            elif recent_low is not None:
                sl_price = float(recent_low - pct_buf)

            if recent_high is not None:
                tp_price = float(recent_high)

            # Fallback: if TP not usable, use RR off structural SL
            if sl_price is not None:
                risk = float(px - sl_price)
                if risk > 0:
                    if tp_price is None or tp_price <= px:
                        tp_price = float(px + rr * risk)

        elif action == 2:  # SHORT
            if ob_bear_top is not None and ob_bear_bottom is not None and ob_bear_top > 0:
                ob_range = max(0.0, float(ob_bear_top - ob_bear_bottom))
                buf = max(pct_buf, 0.25 * ob_range)
                sl_price = float(ob_bear_top + buf)
            elif recent_high is not None:
                sl_price = float(recent_high + pct_buf)

            if recent_low is not None:
                tp_price = float(recent_low)

            if sl_price is not None:
                risk = float(sl_price - px)
                if risk > 0:
                    if tp_price is None or tp_price >= px:
                        tp_price = float(px - rr * risk)
        
        # Prepare Info Dict for Dashboard
        # We want to show key features like FVG presence, OB presence, etc.
        action_str = ["HOLD", "LONG", "SHORT"][int(action)]
        setup_quality = float(np.clip(float(max(long_score, short_score)) / 4.0, 0.0, 1.0))

        # Paper-style analysis + recommendation (Spanish), derived from real features.
        sym = symbol or ""
