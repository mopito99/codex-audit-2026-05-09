def _safe_float(val, default=None):
    try:
        if val is None: return default
        return float(val)
    except (TypeError, ValueError):
        return default

def _json_float(val):
    if val is None: return None
    try:
        f = float(val)
        if np.isfinite(f): return f
    except (TypeError, ValueError):
        pass
    return None

class QuantumEngine:
    def __init__(self, initial_capital=10000.0, *, symbol: str | None = None):
        self.capital = initial_capital
        self.portfolio_value = initial_capital

        self.symbol = str(symbol) if symbol is not None else None
        
        # Shared calendar path
        self.market_context = get_market_context("/srv/profitlab_ai_link/config/event_calendar_usd_high_plus_holidays.csv")
        
        self.feature_calculator = SMCFeatureCalculator()
        self.risk_manager = RiskManager()
        self.risk_manager.set_initial_capital(initial_capital)
        
        # Input dim: OHLCV (5) + SMC Features (approx 14)
        # We need to dynamically determine input_dim or fix it.
        # Let's check the number of features generated by SMCFeatureCalculator
        # For now, we'll use a larger number and pad/truncate or just re-initialize if needed.
        # But better: The agent expects a fixed input size.
        # Let's count the columns in smc_features.py:
        # open, high, low, close, volume (5)
        # fvg_bull_size, fvg_bear_size, is_fvg_bull, is_fvg_bear (4)
        # is_ob_bull, is_ob_bear, ob_top, ob_bottom, ob_bull_top, ob_bull_bottom, ob_bear_top, ob_bear_bottom (8)
        # is_sweep_high, is_sweep_low (2)
        # We build an explicit, stable state vector:
        # 5 OHLCV + 4 FVG + 2 sweeps + 8 OB proximity/freshness + 2 HTF context + 4 Golden Hour = 25
        self.state_columns = [
            # OHLCV (5)
            'open', 'high', 'low', 'close', 'volume',
            # SMC Features (8)
            'fvg_bull_size', 'fvg_bear_size', 'is_fvg_bull', 'is_fvg_bear',
            'is_sweep_high', 'is_sweep_low',
            'bull_ob_distance', 'bear_ob_distance',
            # OB Metadata (6)
            'bull_ob_age', 'bear_ob_age',
            'bull_ob_tests', 'bear_ob_tests',
            'bull_ob_mitigated', 'bear_ob_mitigated',
            # HTF Context (2)
            'htf_bias', 'htf_trend',
            # Golden Hour Features (4)
            'hour_sin', 'hour_cos',
            'is_golden_hour', 'liquidity_score',
            # V2: Technical Indicators (9)
            'rsi_normalized', 'atr_pct',
            'ema_20_dist', 'ema_50_dist', 'ema_200_dist',
            'volume_ratio', 'momentum_5', 'momentum_10', 'trend_strength',
            # V3 PRO: Institutional Indicators (14) - NEW
            'macd_signal_dist',    # MACD - Signal normalized
            'macd_histogram',      # MACD histogram
            'bb_position',         # Bollinger position [0,1]
            'bb_width',            # Bollinger width (volatility)
            'stoch_k',             # Stochastic %K [-1,1]
            'stoch_d',             # Stochastic %D [-1,1]
            'adx_normalized',      # ADX [0,1]
            'obv_slope',           # OBV momentum
            'vwap_dist',           # VWAP distance
            'price_change_1h',     # 1h return
            'price_change_4h',     # 4h return
            'high_low_ratio',      # Candle range / close
            'close_position',      # Close in H-L range [0,1]
            'volume_momentum',     # Volume change rate
        ]
        self.input_dim = len(self.state_columns)  # 48

        def _safe_symbol_for_path(sym: str) -> str:
            s = (sym or "").strip().upper()
            out = []
            for ch in s:
                if ch.isalnum() or ch in ("-", "_", "."):
                    out.append(ch)
                else:
                    out.append("_")
            return "".join(out) or "UNKNOWN"

        def _ppo_weights_path() -> Path:
            if bool(PPO_PER_SYMBOL) and self.symbol:
                sym = _safe_symbol_for_path(self.symbol)
                return Path(str(PPO_WEIGHTS_DIR)) / sym / "ppo.pt"
            return Path(str(PPO_WEIGHTS_PATH))

        if AGENT_TYPE == "decision_transformer":
            # If dt_meta exists, use it to reconstruct the exact architecture.
            dt_cfg = DTConfig(state_dim=self.input_dim, act_dim=3, context_len=int(DT_CONTEXT_LEN))
            meta_path = Path(str(DT_META_PATH))
            if meta_path.exists():
                try:
                    meta = json.loads(meta_path.read_text())
                    dt_cfg = DTConfig(
                        state_dim=self.input_dim,
                        act_dim=3,
                        context_len=int(meta.get("context_len", DT_CONTEXT_LEN)),
                        d_model=int(meta.get("d_model", 128)),
                        nhead=int(meta.get("nhead", 4)),
                        nlayer=int(meta.get("nlayer", 3)),
                    )
                except Exception:
                    pass

            dt_model = DecisionTransformer(dt_cfg)
            weights_path = Path(str(DT_WEIGHTS_PATH))
            if weights_path.exists():
                try:
                    dt_model.load_state_dict(torch.load(str(weights_path), map_location="cpu"))
                except Exception:
                    pass

            self.agent = DecisionTransformerAgent(dt_model, target_rtg=float(DT_TARGET_RTG))
        else:
            weights_path = _ppo_weights_path()
            # In chunked mode (2/day), autosave every update by default.
            autosave_every = 1 if str(PPO_LEARNING_MODE).strip().lower() == "chunked" else None
            self.agent = QuantumAgent(
                input_dim=self.input_dim,
                action_dim=3,
                autosave_path=str(weights_path),
                autosave_every_updates=autosave_every,
                db_url=DATABASE_URL if str(PPO_LEARNING_MODE).strip().lower() == "chunked" else None,
                symbol=self.symbol,
            )  # Buy, Sell, Hold
            if weights_path.exists():
                try:
                    self.agent.load(str(weights_path))
                except Exception:
                    pass
            else:
                # If per-symbol weights are missing, optionally bootstrap from legacy global weights.
                # This avoids starting from scratch while keeping learning isolated per symbol.
                try:
                    legacy = Path(str(PPO_WEIGHTS_PATH))
                    if legacy.exists():
                        self.agent.load(str(legacy))
                except Exception:
                    pass
        
        # Learning State
        self.prev_state = None
        self.prev_action = None
        self.prev_price = None
        self.prev_log_prob = None
        self.prev_value = None
        self._returns_window = []
        self._returns_window_maxlen = 120

        # Chunked learning schedule (per engine/per symbol)
        # OPTIMIZADO 23/01/2026: Cargar último timestamp de entrenamiento desde DB
        self._last_train_ts_ms: int | None = None
        if self.symbol:
            try:
                import psycopg2
                conn = psycopg2.connect(DATABASE_URL)
                cur = conn.cursor()
                cur.execute('''
                    SELECT EXTRACT(EPOCH FROM trained_at) * 1000 
                    FROM ppo_training_log 
                    WHERE symbol = %s 
                    ORDER BY trained_at DESC LIMIT 1
                ''', (self.symbol,))
                row = cur.fetchone()
                if row and row[0]:
                    self._last_train_ts_ms = int(row[0])
                conn.close()
            except Exception:
                pass

        # Cooldown post-SL (evitar revenge trading)
        self._cooldown_until_ts_ms: int = 0

    def maybe_train(self, *, now_ts_ms: int) -> bool:
        """Chunked PPO training: rolling buffer (default 72h) updated every 12h."""
        if not bool(getattr(self.agent, "is_on_policy", True)):
            return False

        if str(PPO_LEARNING_MODE).strip().lower() != "chunked":
            return False

        try:
            window_h = float(PPO_CHUNK_WINDOW_HOURS)
            every_h = float(PPO_CHUNK_UPDATE_EVERY_HOURS)
        except Exception:
            return False

        if window_h <= 0 or every_h <= 0:
            return False

        window_ms = int(window_h * 3600.0 * 1000.0)
        every_ms = int(every_h * 3600.0 * 1000.0)
        min_ts_ms = int(now_ts_ms) - int(window_ms)

        if hasattr(self.agent, "prune_memory"):
            try:
                self.agent.prune_memory(min_ts_ms=int(min_ts_ms))
            except Exception:
                pass

        if self._last_train_ts_ms is None:
            self._last_train_ts_ms = int(now_ts_ms)
            return False

        if int(now_ts_ms) - int(self._last_train_ts_ms) < int(every_ms):
            return False

        min_samples = max(32, int(PPO_CHUNK_MIN_SAMPLES))
        if len(getattr(self.agent, "memory", [])) < int(min_samples):
            return False

        max_samples = int(PPO_CHUNK_MAX_SAMPLES)
        if max_samples > 0 and len(self.agent.memory) > max_samples:
            self.agent.memory = self.agent.memory[-max_samples:]

        try:
            before = int(getattr(self.agent, "_update_count", 0) or 0)
            self.agent.update(clear_memory=False)
            after = int(getattr(self.agent, "_update_count", 0) or 0)
            if after > before:
                self._last_train_ts_ms = int(now_ts_ms)
                return True
            return False
        except Exception:
            return False
        
    # ── step() helper methods (extracted for readability) ──────────────

    def _compute_htf_context(self, htf_data):
        """Compute HTF bias and trend from 1-hour data."""
        htf_bias = 0.0
        htf_trend = 0.0
        if htf_data is not None and not htf_data.empty:
            try:
                htf_features = self.feature_calculator.calculate_all(htf_data)
                htf_state = htf_features.iloc[-1]
                bull = int(htf_state.get('is_ob_bull', 0)) + int(htf_state.get('is_fvg_bull', 0))
                bear = int(htf_state.get('is_ob_bear', 0)) + int(htf_state.get('is_fvg_bear', 0))
                htf_bias = float(np.clip(bull - bear, -2, 2))
                try:
                    htf_close = htf_data['close']
                    if len(htf_close) >= 13:
                        ref = float(htf_close.iloc[-13])
                        last = float(htf_close.iloc[-1])
                        if ref != 0:
                            htf_trend = float(np.clip((last - ref) / ref, -0.05, 0.05))
                except Exception:
                    pass
            except Exception:
                pass
        return htf_bias, htf_trend

    def _compute_time_features(self):
        """Compute golden hour, cyclic time encoding, and liquidity context."""
        try:
            now_utc = pd.Timestamp.now(tz='UTC')
            hour_float = now_utc.hour + now_utc.minute / 60.0
            hour_sin = float(np.sin(2 * np.pi * hour_float / 24.0))
            hour_cos = float(np.cos(2 * np.pi * hour_float / 24.0))
            is_golden_hour = 1.0 if (14.5 <= hour_float <= 17.0) else 0.0
            if (7.0 <= hour_float <= 9.0) or (21.0 <= hour_float <= 23.0):
                is_golden_hour = 0.5
            try:
                m_status = self.market_context.get_status(now_utc)
                liquidity_score = float(m_status.liquidity_score)
            except Exception:
                liquidity_score = 0.5
        except Exception:
            hour_sin = 0.0
            hour_cos = 1.0
            is_golden_hour = 0.0
            liquidity_score = 0.5
        return hour_sin, hour_cos, is_golden_hour, liquidity_score

    def _compute_indicators(self, market_data, row):
        """Compute V3 PRO institutional technical indicators, modifying *row* in-place."""
        try:
            _close = market_data['close'].astype(float)
            _high = market_data['high'].astype(float)
            _low = market_data['low'].astype(float)
            _volume = market_data['volume'].astype(float)
            _n = len(_close)

            # MACD (12, 26, 9)
            _ema12 = _close.ewm(span=12).mean()
            _ema26 = _close.ewm(span=26).mean()
            _macd = _ema12 - _ema26
            _signal = _macd.ewm(span=9).mean()
            _px = float(_close.iloc[-1]) if _n > 0 else 1.0
            row['macd_signal_dist'] = float((_macd.iloc[-1] - _signal.iloc[-1]) / (_px + 1e-10)) if _n > 26 else 0.0
            row['macd_histogram'] = row['macd_signal_dist']

            # Bollinger Bands (20, 2)
            if _n >= 20:
                _bb_mid = _close.rolling(20).mean()
                _bb_std = _close.rolling(20).std()
                _bb_upper = _bb_mid + 2 * _bb_std
                _bb_lower = _bb_mid - 2 * _bb_std
                _bb_range = float(_bb_upper.iloc[-1] - _bb_lower.iloc[-1])
                row['bb_position'] = float((_px - _bb_lower.iloc[-1]) / (_bb_range + 1e-10))
                row['bb_width'] = float(_bb_range / (_bb_mid.iloc[-1] + 1e-10))
            else:
                row['bb_position'] = 0.5
                row['bb_width'] = 0.0

            # Stochastic (14, 3)
            if _n >= 14:
                _low14 = _low.rolling(14).min()
                _high14 = _high.rolling(14).max()
                _stoch_k = (_close - _low14) / (_high14 - _low14 + 1e-10)
                _stoch_d = _stoch_k.rolling(3).mean()
                row['stoch_k'] = float((_stoch_k.iloc[-1] - 0.5) * 2)
                row['stoch_d'] = float((_stoch_d.iloc[-1] - 0.5) * 2) if _n >= 16 else 0.0
            else:
                row['stoch_k'] = 0.0
                row['stoch_d'] = 0.0

            # ADX (14)
            if _n >= 28:
                _plus_dm = _high.diff().clip(lower=0)
                _minus_dm = (-_low.diff()).clip(lower=0)
                _tr = pd.concat([_high - _low, (_high - _close.shift(1)).abs(), (_low - _close.shift(1)).abs()], axis=1).max(axis=1)
                _atr14 = _tr.rolling(14).mean()
                _plus_di = (_plus_dm.rolling(14).mean() / (_atr14 + 1e-10)) * 100
                _minus_di = (_minus_dm.rolling(14).mean() / (_atr14 + 1e-10)) * 100
                _dx = (_plus_di - _minus_di).abs() / (_plus_di + _minus_di + 1e-10) * 100
                _adx = _dx.rolling(14).mean()
                row['adx_normalized'] = float(_adx.iloc[-1] / 100.0)
            else:
                row['adx_normalized'] = 0.0

            # OBV slope
            if _n >= 20:
                _obv = (np.sign(_close.diff()) * _volume).fillna(0).cumsum()
                _obv_ma = _obv.rolling(20).mean()
                row['obv_slope'] = float((_obv.iloc[-1] - _obv_ma.iloc[-1]) / (abs(_obv_ma.iloc[-1]) + 1e-10))
            else:
                row['obv_slope'] = 0.0

            # VWAP distance (rolling 288 ~ 1 day of 5m candles)
            if _n >= 50:
                _tp = (_high + _low + _close) / 3
                _window = min(288, _n)
                _cum_vol = _volume.rolling(_window).sum()
                _cum_tpv = (_tp * _volume).rolling(_window).sum()
                _vwap = _cum_tpv / (_cum_vol + 1e-10)
                row['vwap_dist'] = float((_px - _vwap.iloc[-1]) / (_px + 1e-10))
            else:
                row['vwap_dist'] = 0.0

            # Multi-TF price changes
            row['price_change_1h'] = float(_close.pct_change(12).iloc[-1]) if _n > 12 else 0.0
            row['price_change_4h'] = float(_close.pct_change(48).iloc[-1]) if _n > 48 else 0.0

            # Volatility and structure
            row['high_low_ratio'] = float((_high.iloc[-1] - _low.iloc[-1]) / (_px + 1e-10))
            row['close_position'] = float((_px - _low.iloc[-1]) / (_high.iloc[-1] - _low.iloc[-1] + 1e-10))

            # Volume momentum
            row['volume_momentum'] = float(_volume.pct_change(5).iloc[-1]) if _n > 5 else 0.0

        except Exception:
            for _col in ['macd_signal_dist', 'macd_histogram', 'bb_position', 'bb_width',
                         'stoch_k', 'stoch_d', 'adx_normalized', 'obv_slope', 'vwap_dist',
                         'price_change_1h', 'price_change_4h', 'high_low_ratio',
                         'close_position', 'volume_momentum']:
                row[_col] = row.get(_col, 0.0)

    def _build_state_vector(self, row):
        """Build and normalize the state vector from the enriched feature row."""
        state_values = []
        for col in self.state_columns:
            try:
                v = row.get(col, 0.0)
                if v is None or (isinstance(v, float) and not np.isfinite(v)):
                    v = 0.0
                state_values.append(float(v))
            except Exception:
                state_values.append(0.0)
        state_vector = np.array(state_values, dtype=np.float32)
        finite = np.isfinite(state_vector)
        if finite.any():
            scale = float(np.median(np.abs(state_vector[finite])))
        else:
            scale = 1.0
        if not np.isfinite(scale) or scale <= 1e-8:
            scale = 1.0
        return np.clip(state_vector / scale, -10.0, 10.0)

    def _reward_entry_quality(self, current_state, current_price):
        """Bonus for entries near OB/FVG zones."""
        try:
            bull_dist = float(current_state.get('bull_ob_distance', 999) or 999)
            bear_dist = float(current_state.get('bear_ob_distance', 999) or 999)
            px = float(current_price) if current_price else 1.0
            prox_threshold = px * 0.005
            if ((self.prev_action == 1 and bull_dist < prox_threshold)
                    or (self.prev_action == 2 and bear_dist < prox_threshold)):
                return 0.3
        except Exception:
            pass
        return 0.0

    def _reward_htf_alignment(self, current_state):
        """Bonus/penalty for HTF trend alignment."""
        try:
            htf_trend_val = float(current_state.get('htf_trend', 0) or 0)
            if self.prev_action == 1 and htf_trend_val > 0.002:
                return 0.2
            if self.prev_action == 2 and htf_trend_val < -0.002:
                return 0.2
            if self.prev_action == 1 and htf_trend_val < -0.003:
                return -0.3
            if self.prev_action == 2 and htf_trend_val > 0.003:
                return -0.3
        except Exception:
            pass
        return 0.0

    def _reward_hold(self, pct_change):
        """Reward/penalty for hold decisions based on missed moves."""
        if self.prev_action != 0:
            return 0.0
        if abs(pct_change) > 0.005:
            return -0.4
        if abs(pct_change) > 0.003:
            return -0.2
        if abs(pct_change) < 0.001:
            return 0.15
        return 0.0

    def _compute_reward_and_learn(self, current_price, current_state, now_ts_ms):
        """Compute multi-factor PPO reward for previous step and store transition."""
        if not (bool(getattr(self.agent, "is_on_policy", True))
                and self.prev_state is not None
                and self.prev_action is not None):
            return
        pct_change = (current_price - self.prev_price) / self.prev_price if self.prev_price else 0.0

        if self.prev_action == 1:  # Long
            realized_r = float(pct_change)
        elif self.prev_action == 2:  # Short
            realized_r = float(-pct_change)
        else:  # Hold
            realized_r = 0.0

        # Multi-factor reward
        base_reward = realized_r * 100.0 if realized_r > 0 else realized_r * 200.0
        reward = (base_reward
                  + self._reward_entry_quality(current_state, current_price)
                  + self._reward_htf_alignment(current_state)
                  + self._reward_hold(pct_change))

        # Store transition
        if hasattr(self.agent, "remember"):
            try:
                self.agent.remember(
                    self.prev_state, self.prev_action, float(reward), False,
                    self.prev_log_prob, self.prev_value, int(now_ts_ms))
            except TypeError:
                self.agent.remember(
                    self.prev_state, self.prev_action, float(reward), False,
                    self.prev_log_prob, self.prev_value)

        # Online learning mode: update immediately
        if str(PPO_LEARNING_MODE).strip().lower() == "online":
            if hasattr(self.agent, "update"):
                self.agent.update(clear_memory=True)

    def _extract_smc_zones(self, current_state, current_price):
        """Extract SMC zone data (OB, FVG, sweeps) for confluence analysis."""
        px = float(current_price) if current_price else 0.0
        prox_limit = px * 0.003

        sweep_low = int(current_state.get('is_sweep_low', 0) or 0)
        sweep_high = int(current_state.get('is_sweep_high', 0) or 0)

        bull_dist = float(current_state.get('bull_ob_distance', 999) or 999)
        bear_dist = float(current_state.get('bear_ob_distance', 999) or 999)
        near_bull_ob = int(bull_dist < prox_limit)
        near_bear_ob = int(bear_dist < prox_limit)

        bull_ob_age = float(current_state.get('bull_ob_age', 0.0) or 0.0)
        bear_ob_age = float(current_state.get('bear_ob_age', 0.0) or 0.0)
        bull_ob_mit = int(current_state.get('bull_ob_mitigated', 0) or 0)
        bear_ob_mit = int(current_state.get('bear_ob_mitigated', 0) or 0)

        fvg_bull_dist = _safe_float(current_state.get('fvg_bull_distance'))
        fvg_bear_dist = _safe_float(current_state.get('fvg_bear_distance'))
        fvg_bull_age = float(current_state.get('fvg_bull_age', 0.0) or 0.0)
        fvg_bear_age = float(current_state.get('fvg_bear_age', 0.0) or 0.0)
        fvg_bull_mit = int(current_state.get('fvg_bull_mitigated', 0) or 0)
        fvg_bear_mit = int(current_state.get('fvg_bear_mitigated', 0) or 0)

        fvg_bull_ok = int(fvg_bull_dist is not None and fvg_bull_dist < prox_limit)
        fvg_bear_ok = int(fvg_bear_dist is not None and fvg_bear_dist < prox_limit)

        # Only unmitigated zones count
        valid_bull_ob = (near_bull_ob == 1) and (bull_ob_mit == 0)
        valid_bear_ob = (near_bear_ob == 1) and (bear_ob_mit == 0)
        valid_bull_fvg = (fvg_bull_ok == 1) and (fvg_bull_mit == 0)
        valid_bear_fvg = (fvg_bear_ok == 1) and (fvg_bear_mit == 0)

        has_bull_setup = bool(sweep_low or valid_bull_ob or valid_bull_fvg)
        has_bear_setup = bool(sweep_high or valid_bear_ob or valid_bear_fvg)

        return {
            'near_bull_ob': near_bull_ob, 'near_bear_ob': near_bear_ob,
            'bull_ob_dist': bull_dist, 'bear_ob_dist': bear_dist,
            'bull_ob_age': bull_ob_age, 'bear_ob_age': bear_ob_age,
            'bull_ob_mit': bull_ob_mit, 'bear_ob_mit': bear_ob_mit,
            'fvg_bull_dist': fvg_bull_dist, 'fvg_bear_dist': fvg_bear_dist,
            'fvg_bull_age': fvg_bull_age, 'fvg_bear_age': fvg_bear_age,
            'fvg_bull_mit': fvg_bull_mit, 'fvg_bear_mit': fvg_bear_mit,
            'fvg_bull_ok': fvg_bull_ok, 'fvg_bear_ok': fvg_bear_ok,
            'sweep_low': sweep_low, 'sweep_high': sweep_high,
            'has_bull_setup': has_bull_setup, 'has_bear_setup': has_bear_setup,
        }

    def _make_trade_decision(self, action, probs, htf_trend, zones):
        """Apply trend + confidence + confluence gates. Returns (final_action, scores dict)."""
        prob_long = probs[1]
        prob_short = probs[2]

        is_uptrend = htf_trend > 0.003
        is_downtrend = htf_trend < -0.003

        CONFIDENCE_THRESHOLD = 0.45
        TREND_BLOCK_THRESHOLD = 0.003

        # Trend direction filter
        if htf_trend < -TREND_BLOCK_THRESHOLD:
            allow_long, allow_short = 0, 1
            print(f"Trend Filter: DOWNTREND ({htf_trend:.4f}) -> LONG blocked")
        elif htf_trend > TREND_BLOCK_THRESHOLD:
            allow_long, allow_short = 1, 0
            print(f"Trend Filter: UPTREND ({htf_trend:.4f}) -> SHORT blocked")
        else:
            allow_long, allow_short = 1, 1

        # Confluence scores (0-4)
        long_score = sum([is_uptrend, zones['has_bull_setup'], prob_long > 0.40, prob_long > 0.60])
        short_score = sum([is_downtrend, zones['has_bear_setup'], prob_short > 0.40, prob_short > 0.60])

        # Decision: PPO + confidence + trend + confluence
        final_action = 0
        MIN_CONFLUENCE = 2

        if (action == 1 and prob_long > CONFIDENCE_THRESHOLD
                and allow_long == 1 and long_score >= MIN_CONFLUENCE):
            final_action = 1
            print(f"  LONG APPROVED: prob={prob_long:.3f}, allow={allow_long}, score={long_score}/4")
        elif (action == 2 and prob_short > CONFIDENCE_THRESHOLD
                and allow_short == 1 and short_score >= MIN_CONFLUENCE):
            final_action = 2
            print(f"  SHORT APPROVED: prob={prob_short:.3f}, allow={allow_short}, score={short_score}/4")
        elif action != 0:
            reasons = []
            if action == 1:
                if prob_long <= CONFIDENCE_THRESHOLD:
                    reasons.append(f"conf={prob_long:.3f}<{CONFIDENCE_THRESHOLD}")
                if allow_long == 0:
                    reasons.append("counter-trend")
                if long_score < MIN_CONFLUENCE:
                    reasons.append(f"score={long_score}<{MIN_CONFLUENCE}")
            else:
                if prob_short <= CONFIDENCE_THRESHOLD:
                    reasons.append(f"conf={prob_short:.3f}<{CONFIDENCE_THRESHOLD}")
                if allow_short == 0:
                    reasons.append("counter-trend")
                if short_score < MIN_CONFLUENCE:
                    reasons.append(f"score={short_score}<{MIN_CONFLUENCE}")
            act_name = "LONG" if action == 1 else "SHORT"
            print(f"  {act_name} BLOCKED -> HOLD: {', '.join(reasons)}")

        return final_action, {
            'long_score': long_score, 'short_score': short_score,
            'allow_long': allow_long, 'allow_short': allow_short,
        }

    def _apply_confluence_filter(self, action, probs, htf_trend, current_state, current_price):
        """Apply trend + SMC + confidence gating. Returns dict with filtered action and reporting vars."""
        zones = self._extract_smc_zones(current_state, current_price)
        final_action, scores = self._make_trade_decision(action, probs, htf_trend, zones)

        result = dict(zones)
        result['action'] = final_action
        result.update(scores)
        return result

    def _compute_risk_sizing(self, action, market_data, long_score, short_score):
        """CPPI + vol targeting + league leverage sizing."""
        # Market context (event risk, holidays)
        try:
            m_status = self.market_context.get_status(pd.Timestamp.now(tz='UTC'))
            event_mult = float(m_status.position_size_multiplier)
            is_paused = "pause" in str(m_status.trading_mode).lower()
        except Exception:
            event_mult = 1.0
            is_paused = False

        # Volatility (annualized from 5m data)
        ann_factor = 324.2
        current_vol = market_data['close'].pct_change().rolling(window=20).std().iloc[-1] * ann_factor
        if np.isnan(current_vol):
            current_vol = 0.60

        # Hard brakes
        if self.risk_manager.floor_value is not None and self.portfolio_value <= self.risk_manager.floor_value:
            action = 0
        if is_paused:
            action = 0

        max_leverage = 10.0
        setup_quality = float(max(long_score, short_score)) / 4.0
        setup_quality = float(np.clip(setup_quality, 0.0, 1.0))
        setup_quality = max(setup_quality, 0.25)

        # CPPI margin cap
        cushion = float(self.portfolio_value - float(self.risk_manager.floor_value or 0.0))
        margin_cap_usd = float(self.risk_manager.cppi_multiplier) * max(0.0, cushion)
        margin_cap_usd = float(np.clip(margin_cap_usd, 0.0, float(self.portfolio_value)))

        # Vol targeting desired notional
        desired_notional_raw = float(self.risk_manager.calculate_vol_targeting_position(current_vol, self.portfolio_value))

        # Institutional confidence filter (minimum viable ticket)
        min_margin_usd = 10.0
        if margin_cap_usd < min_margin_usd and self.portfolio_value > (min_margin_usd * 2.0):
            if setup_quality >= 0.60:
                print(f"Risk Override: Upgrading margin to ${min_margin_usd} due to High Confidence ({setup_quality:.2f})")
                margin_cap_usd = min_margin_usd
            elif margin_cap_usd < 1.0:
                margin_cap_usd = 0.0

        desired_notional = float(desired_notional_raw) * float(setup_quality) * event_mult

        # Dynamic leverage by league
        league_max_leverage = get_cached_league_leverage()

        # Safe size (max allowed if a trade were taken)
        if margin_cap_usd <= 0.0:
            safe_size = 0.0
        else:
            safe_size = float(min(float(desired_notional_raw), float(margin_cap_usd) * float(max_leverage)))

        if action == 0 or margin_cap_usd <= 0.0:
            notional_usd = 0.0
            leverage = 1.0
            margin_usd = 0.0
        else:
            margin_usd = float(margin_cap_usd)
            if league_max_leverage > 1.0:
                leverage = float(league_max_leverage)
            elif not np.isfinite(desired_notional) or desired_notional <= 0.0:
                leverage = 1.0
            else:
                leverage = float(np.clip(desired_notional / margin_usd, 1.0, max_leverage))
            notional_usd = float(margin_usd) * float(leverage)

        print(f"Action: {action}, Margin: {margin_usd:.2f}, Lev: {leverage:.2f}x, Notional: {notional_usd:.2f}, Portfolio: {self.portfolio_value:.2f}")

        return {
            'action': action,
            'margin_usd': margin_usd,
            'leverage': leverage,
            'notional_usd': notional_usd,
            'safe_size': safe_size,
            'setup_quality': setup_quality,
            'current_vol': current_vol,
        }

    def _place_structural_sl_tp(self, action, px, current_state, market_data):
        """Place SL/TP based on OB zones and swing liquidity pools."""
        sl_price = None
        tp_price = None
        rr = 2.0

        try:
            lookback_liq = 20
            recent_high = float(market_data['high'].iloc[-(lookback_liq + 1):-1].max())
            recent_low = float(market_data['low'].iloc[-(lookback_liq + 1):-1].min())
        except Exception:
            recent_high = None
            recent_low = None

        ob_bull_top = _safe_float(current_state.get('active_ob_bull_top', None), default=None)
        ob_bull_bottom = _safe_float(current_state.get('active_ob_bull_bottom', None), default=None)
        ob_bear_top = _safe_float(current_state.get('active_ob_bear_top', None), default=None)
        ob_bear_bottom = _safe_float(current_state.get('active_ob_bear_bottom', None), default=None)

        pct_buf = abs(px) * 0.005  # 0.50% institutional buffer

        if action == 1:  # LONG
            if ob_bull_bottom is not None and ob_bull_top is not None and ob_bull_bottom > 0:
                ob_range = max(0.0, float(ob_bull_top - ob_bull_bottom))
                buf = max(pct_buf, 0.50 * ob_range)
                sl_price = float(ob_bull_bottom - buf)
            elif recent_low is not None:
                sl_price = float(recent_low - pct_buf)
            if recent_high is not None:
                tp_price = float(recent_high)
            if sl_price is not None:
                risk = float(px - sl_price)
                if risk > 0 and (tp_price is None or tp_price <= px):
                    tp_price = float(px + rr * risk)

        elif action == 2:  # SHORT
            if ob_bear_top is not None and ob_bear_bottom is not None and ob_bear_top > 0:
                ob_range = max(0.0, float(ob_bear_top - ob_bear_bottom))
                buf = max(pct_buf, 0.50 * ob_range)
                sl_price = float(ob_bear_top + buf)
            elif recent_high is not None:
                sl_price = float(recent_high + pct_buf)
            if recent_low is not None:
                tp_price = float(recent_low)
            if sl_price is not None:
                risk = float(sl_price - px)
                if risk > 0 and (tp_price is None or tp_price >= px):
                    tp_price = float(px - rr * risk)

        return sl_price, tp_price

    def _enforce_sl_tp_limits(self, action, px, sl_price, tp_price):
        """Enforce minimum SL/TP distances and R:R ratio."""
        MIN_TP_PCT = 0.020
        MIN_SL_PCT = 0.008

        if px > 0 and sl_price is not None:
            sl_dist_pct = abs(px - sl_price) / px
            if sl_dist_pct < MIN_SL_PCT:
                sl_price = float(px * (1 - MIN_SL_PCT)) if action == 1 else float(px * (1 + MIN_SL_PCT))
                print(f"SL Widened: {sl_dist_pct*100:.2f}% -> {MIN_SL_PCT*100:.1f}% (noise filter)")

        if px > 0 and tp_price is not None:
            tp_dist_pct = abs(tp_price - px) / px
            if tp_dist_pct < MIN_TP_PCT:
                tp_price = float(px * (1 + MIN_TP_PCT)) if action == 1 else float(px * (1 - MIN_TP_PCT))
                print(f"TP Widened: {tp_dist_pct*100:.2f}% -> {MIN_TP_PCT*100:.1f}% (fee coverage)")

        # v8: R:R sanity check (min 2:1)
        MIN_RR = 2.0
        if sl_price is not None and tp_price is not None:
            risk_dist = abs(px - sl_price)
            reward_dist = abs(tp_price - px)
            if risk_dist > 0:
                current_rr = reward_dist / risk_dist
                if current_rr < MIN_RR:
                    new_reward = risk_dist * MIN_RR
                    tp_price = float(px + new_reward) if action == 1 else float(px - new_reward)
                    print(f"R:R Fix: {current_rr:.2f} -> {MIN_RR:.1f} (TP widened to {tp_price:.2f})")

        return sl_price, tp_price

    def _compute_sl_tp(self, action, current_price, current_state, market_data):
        """Compute SL/TP from SMC structures with minimum distance and R:R enforcement."""
        if action == 0:
            return None, None
        px = float(current_price) if current_price else 0.0
        sl_price, tp_price = self._place_structural_sl_tp(action, px, current_state, market_data)
        return self._enforce_sl_tp_limits(action, px, sl_price, tp_price)

    def _build_info_dict(self, action, symbol, htf_bias, htf_trend, current_state,
                         cf, risk, sl_price, tp_price, probs, microstructure):
        """Build the dashboard info dictionary."""
        action_str = ["HOLD", "LONG", "SHORT"][int(action)]
        setup_quality = risk['setup_quality']

        sym = symbol or ""
        header = f"{sym} " if sym else ""

        # Agent metadata
        if AGENT_TYPE == "decision_transformer":
            agent_backbone = "decision_transformer"
            agent_seq_len = int(getattr(getattr(self.agent, "cfg", None), "context_len", 0) or int(DT_CONTEXT_LEN))
        else:
            agent_backbone = "transformer_encoder" if bool(getattr(self.agent.model, "use_transformer", False)) else "mlp"
            agent_seq_len = int(getattr(self.agent, "seq_len", 0) or 0)

        ms = microstructure or {}
        ms_mid = _safe_float(ms.get("mid"), default=None)
        ms_spread_bps = _safe_float(ms.get("spread_bps"), default=None)
        ms_imb = _safe_float(ms.get("imbalance"), default=None)
        ms_bid_usd = _safe_float(ms.get("bid_depth_usd"), default=None)
        ms_ask_usd = _safe_float(ms.get("ask_depth_usd"), default=None)

        if AGENT_TYPE == "decision_transformer":
            agent_line = f"Agente: Decision Transformer (context_len={agent_seq_len})"
        else:
            agent_line = f"Agente: PPO + {agent_backbone} (seq_len={agent_seq_len})"

        analysis_lines = [
            agent_line,
            f"{header}Marco 1H: bias={htf_bias:.2f}, trend={htf_trend:.4f}",
            f"Ejecucion 5m: sweep_low={cf['sweep_low']}, sweep_high={cf['sweep_high']}",
            f"Microestructura: mid={ms_mid if ms_mid is not None else 'NA'}, spread_bps={ms_spread_bps if ms_spread_bps is not None else 'NA'}, imbalance={ms_imb if ms_imb is not None else 'NA'}",
            f"OB: near_bull={cf['near_bull_ob']}, near_bear={cf['near_bear_ob']}, dist_bull={cf['bull_ob_dist'] if cf['bull_ob_dist'] is not None else 'NA'}, dist_bear={cf['bear_ob_dist'] if cf['bear_ob_dist'] is not None else 'NA'}, age_bull={cf['bull_ob_age']:.0f}, age_bear={cf['bear_ob_age']:.0f}, mit_bull={cf['bull_ob_mit']}, mit_bear={cf['bear_ob_mit']}",
            f"FVG: bull_ok={cf['fvg_bull_ok']}, bear_ok={cf['fvg_bear_ok']}, dist_bull={cf['fvg_bull_dist'] if cf['fvg_bull_dist'] is not None else 'NA'}, dist_bear={cf['fvg_bear_dist'] if cf['fvg_bear_dist'] is not None else 'NA'}, age_bull={cf['fvg_bull_age']:.0f}, age_bear={cf['fvg_bear_age']:.0f}, mit_bull={cf['fvg_bull_mit']}, mit_bear={cf['fvg_bear_mit']}",
            f"Confluencia (0-4): long={cf['long_score']}, short={cf['short_score']} | umbral=3 (institucional)",
            f"Recomendacion (paper): {action_str} | confianza={setup_quality:.2f}",
        ]
        if action != 0:
            analysis_lines.append(f"Plan: SL={sl_price}, TP={tp_price} (Single SL / Single TP, sin parciales)")

        return {
            "features": {
                "fvg_bull": int(current_state.get('is_fvg_bull', 0)),
                "fvg_bear": int(current_state.get('is_fvg_bear', 0)),
                "ob_bull": int(current_state.get('is_ob_bull', 0)),
                "ob_bear": int(current_state.get('is_ob_bear', 0)),
                "sweep_high": int(current_state.get('is_sweep_high', 0)),
                "sweep_low": int(current_state.get('is_sweep_low', 0)),
                "near_bull_ob": int(cf['near_bull_ob']),
                "near_bear_ob": int(cf['near_bear_ob']),
                "htf_bias": float(htf_bias),
                "htf_trend": float(htf_trend),
                "setup_long_score": int(cf['long_score']),
                "setup_short_score": int(cf['short_score']),
                "allow_long": int(cf['allow_long']),
                "allow_short": int(cf['allow_short']),
                "recommendation": action_str,
                "confidence": float(setup_quality),
                "analysis": "\n".join(analysis_lines),
                "agent_backbone": agent_backbone,
                "agent_seq_len": int(agent_seq_len),
                "ms_mid": _json_float(ms_mid),
                "ms_spread_bps": _json_float(ms_spread_bps),
                "ms_imbalance": _json_float(ms_imb),
                "ms_bid_depth_usd": _json_float(ms_bid_usd),
                "ms_ask_depth_usd": _json_float(ms_ask_usd),
                "bull_ob_distance": _json_float(current_state.get('bull_ob_distance', None)),
                "bear_ob_distance": _json_float(current_state.get('bear_ob_distance', None)),
                "bull_ob_age": float(current_state.get('bull_ob_age', 0.0) or 0.0),
                "bear_ob_age": float(current_state.get('bear_ob_age', 0.0) or 0.0),
                "bull_ob_tests": float(current_state.get('bull_ob_tests', 0.0) or 0.0),
                "bear_ob_tests": float(current_state.get('bear_ob_tests', 0.0) or 0.0),
                "bull_ob_mitigated": int(current_state.get('bull_ob_mitigated', 0) or 0),
                "bear_ob_mitigated": int(current_state.get('bear_ob_mitigated', 0) or 0),
                "fvg_bull_distance": _json_float(current_state.get('fvg_bull_distance', None)),
                "fvg_bear_distance": _json_float(current_state.get('fvg_bear_distance', None)),
                "fvg_bull_age": float(current_state.get('fvg_bull_age', 0.0) or 0.0),
                "fvg_bear_age": float(current_state.get('fvg_bear_age', 0.0) or 0.0),
                "fvg_bull_tests": float(current_state.get('fvg_bull_tests', 0.0) or 0.0),
                "fvg_bear_tests": float(current_state.get('fvg_bear_tests', 0.0) or 0.0),
                "fvg_bull_mitigated": int(current_state.get('fvg_bull_mitigated', 0) or 0),
                "fvg_bear_mitigated": int(current_state.get('fvg_bear_mitigated', 0) or 0),
                "close_price": float(current_state.get('close', 0))
            },
            "probs": probs,
            "orders": {"sl": sl_price, "tp": tp_price},
            "risk": {
                "volatility": float(risk.get('current_vol', 0.6)),
                "safe_size": float(risk['safe_size']),
                "margin_usd": float(risk['margin_usd']),
                "leverage": float(risk['leverage']),
                "notional_usd": float(risk['notional_usd']),
                "cppi_floor": float(self.risk_manager.floor_value)
            }
        }

    def step(
        self,
        market_data: pd.DataFrame,
        htf_data: pd.DataFrame | None = None,
        symbol: str | None = None,
        microstructure: dict | None = None,
    ):
        """Execute one step of the trading loop."""
        # Timestamp for scheduling/training (prefer kline time)
        now_ts_ms = None
        try:
            if "time" in market_data.columns and len(market_data) > 0:
                now_ts_ms = int(market_data["time"].iloc[-1])
        except Exception:
            now_ts_ms = None
        if now_ts_ms is None:
            now_ts_ms = int(pd.Timestamp.utcnow().value // 1_000_000)

        # 1. Calculate Features (5m execution layer)
        features = self.feature_calculator.calculate_all(market_data)
        current_state = features.iloc[-1]

        htf_bias, htf_trend = self._compute_htf_context(htf_data)
        hour_sin, hour_cos, is_golden_hour, liquidity_score = self._compute_time_features()

        # Build enriched state row
        row = features.iloc[-1].copy()
        row['htf_bias'] = float(htf_bias)
        row['htf_trend'] = float(htf_trend)
        row['hour_sin'] = float(hour_sin)
        row['hour_cos'] = float(hour_cos)
        row['is_golden_hour'] = float(is_golden_hour)
        row['liquidity_score'] = float(liquidity_score)

        self._compute_indicators(market_data, row)
        state_vector = self._build_state_vector(row)

        # 2. Get Agent Action (PPO on-policy)
        action, log_prob, value, policy, seq_state = self.agent.get_action(state_vector)
        probs = policy.detach().cpu().numpy().tolist()
        current_price = float(current_state.get('close', 0))

        # Continuous learning: reward for previous step
        self._compute_reward_and_learn(current_price, current_state, now_ts_ms)

        # 2.1 Confluence filter (trend + SMC + confidence gating)
        cf = self._apply_confluence_filter(action, probs, htf_trend, current_state, current_price)
        action = cf['action']

        # Re-compute log_prob for gated action
        try:
            dist = torch.distributions.Categorical(policy)
            action_t = torch.tensor([action], device=self.agent.device)
            log_prob = dist.log_prob(action_t).squeeze(0)
        except Exception:
            pass

        # Update state for next step (store gated action)
        self.prev_state = seq_state
        self.prev_action = action
        self.prev_price = current_price
        self.prev_log_prob = log_prob
        self.prev_value = value

        # Chunked PPO update (2/day) using rolling 72h window
        if str(PPO_LEARNING_MODE).strip().lower() == "chunked":
            self.maybe_train(now_ts_ms=int(now_ts_ms))

        # 3. Risk Management (CPPI + vol targeting + league leverage)
        risk = self._compute_risk_sizing(action, market_data, cf['long_score'], cf['short_score'])
        action = risk['action']

        # 3.1 SL/TP (SMC-derived)
        sl_price, tp_price = self._compute_sl_tp(action, current_price, current_state, market_data)

        # Cooldown check (no revenge trading after SL)
        if action != 0 and now_ts_ms < self._cooldown_until_ts_ms:
            cooldown_left_s = (self._cooldown_until_ts_ms - now_ts_ms) / 1000.0
            print(f"Cooldown active: {cooldown_left_s:.0f}s remaining, skipping trade.")
            action = 0

        # 4. Build info dict for dashboard
        info = self._build_info_dict(
            action, symbol, htf_bias, htf_trend, current_state,
            cf, risk, sl_price, tp_price, probs, microstructure)

        # 5. Execute (Simulation)
        return action, risk['notional_usd'], info

if __name__ == "__main__":
    # Test run
    rng = np.random.default_rng(42)
    data = {
        'open': rng.normal(100, 5, 100),
        'high': rng.normal(102, 5, 100),
        'low': rng.normal(98, 5, 100),
        'close': rng.normal(100, 5, 100),
        'volume': rng.normal(1000, 100, 100)
    }
    df = pd.DataFrame(data)
    
    engine = QuantumEngine()
    engine.step(df)
